<div class="toast-container" id="toastContainer"></div>

<script>
    const currentUserName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(currentUserName));
    const logoutUrl = '@Url.Action("Logout", "Auth")';
    const homeUrl = '@Url.Action("Index", "Home")';

    let users = [
        { id: "USR-001", name: "Rafael Parra", email: "rafael.parra@bugtrack.dev", initials: "RP", avClass: "av-rp", role: "Administrator", status: "Active", department: "Engineering", assignedTickets: 3, resolvedTickets: 8, openCritical: 1, lastActive: "Just now", joined: "May 2026", activity: ["Created the BugTrack demo workspace.", "Updated ticket #1047.", "Reviewed critical issue #1045."] },
        { id: "USR-002", name: "Maya Chen", email: "maya.chen@bugtrack.dev", initials: "MC", avClass: "av-mc", role: "Developer", status: "Away", department: "Engineering", assignedTickets: 1, resolvedTickets: 4, openCritical: 0, lastActive: "34 min ago", joined: "May 2026", activity: ["Submitted pagination changes for review.", "Commented on user management grid ticket.", "Moved ticket #1046 to Review."] },
        { id: "USR-003", name: "Sofia Patel", email: "sofia.patel@bugtrack.dev", initials: "SP", avClass: "av-sp", role: "QA Analyst", status: "Active", department: "Quality Assurance", assignedTickets: 0, resolvedTickets: 6, openCritical: 0, lastActive: "12 min ago", joined: "May 2026", activity: ["Verified dark mode settings toggle.", "Closed ticket #1044.", "Added QA notes to resolved tickets."] },
        { id: "USR-004", name: "Theo Kowalski", email: "theo.kowalski@bugtrack.dev", initials: "TK", avClass: "av-tk", role: "Support Lead", status: "Active", department: "Customer Support", assignedTickets: 2, resolvedTickets: 3, openCritical: 0, lastActive: "5 min ago", joined: "May 2026", activity: ["Opened login timeout ticket.", "Added customer reproduction details.", "Escalated session bug to High priority."] }
    ];

    let selectedUserId = users.length ? users[0].id : null;
    let editingUserId = null;
    let deletingUserId = null;
    let nextUserNumber = 5;
    let sortCol = null;
    let sortDir = "asc";

    function badgeClass(value) {
        const map = { "administrator": "admin", "developer": "developer", "qa analyst": "qa", "support lead": "support", "active": "active", "away": "away", "inactive": "inactive" };
        return map[value.toLowerCase()] || "inactive";
    }

    function getInitials(name) {
        return name.split(" ").map(x => x.charAt(0)).join("").substring(0, 2).toUpperCase();
    }

    function getAvClass(initials) {
        const map = { RP: "av-rp", MC: "av-mc", SP: "av-sp", TK: "av-tk" };
        return map[initials] || "av-mc";
    }

    function isMobile() { return window.innerWidth <= 860; }

    function toast(message, type = "success") {
        const icons = {
            success: `<svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>`,
            error: `<svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`,
            info: `<svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`
        };
        const el = document.createElement("div");
        el.className = `toast toast-${type}`;
        el.innerHTML = `<div class="toast-icon">${icons[type]}</div><span>${message}</span>`;
        document.getElementById("toastContainer")?.appendChild(el);
        requestAnimationFrame(() => { requestAnimationFrame(() => el.classList.add("show")); });
        setTimeout(() => { el.classList.add("leaving"); setTimeout(() => el.remove(), 300); }, 3000);
    }

    function openModal(id) { document.getElementById(id).classList.add("show"); document.body.style.overflow = "hidden"; }
    function closeModal(id) { document.getElementById(id).classList.remove("show"); document.body.style.overflow = ""; }

    document.querySelectorAll("[data-close]").forEach(btn => btn.addEventListener("click", () => closeModal(btn.dataset.close)));
    document.querySelectorAll(".modal-backdrop").forEach(backdrop => {
        backdrop.addEventListener("click", e => { if (e.target === backdrop) closeModal(backdrop.id); });
    });
    document.addEventListener("keydown", e => {
        if (e.key === "Escape") {
            document.querySelectorAll(".modal-backdrop.show").forEach(m => closeModal(m.id));
            closeMobileSidebar();
            closeMobileSearch();
        }
    });

    // ===== MOBILE SEARCH =====
    const mobileSearchBar = document.getElementById("mobileSearchBar");
    const mobileSearchInput = document.getElementById("mobileSearchInput");

    function openMobileSearch() {
        mobileSearchBar.classList.add("open");
        setTimeout(() => mobileSearchInput.focus(), 80);
    }
    function closeMobileSearch() {
        mobileSearchBar.classList.remove("open");
        mobileSearchInput.value = "";
        document.getElementById("topSearch").value = "";
        renderUsers();
    }

    document.getElementById("mobileSearchToggle").addEventListener("click", openMobileSearch);
    document.getElementById("closeMobileSearch").addEventListener("click", closeMobileSearch);
    mobileSearchInput.addEventListener("input", () => {
        document.getElementById("topSearch").value = mobileSearchInput.value;
        renderUsers();
    });

    // ===== FILTERS =====
    function getFilteredUsers() {
        const search = document.getElementById("topSearch").value.toLowerCase().trim();
        const role = document.getElementById("roleFilter").value;
        const status = document.getElementById("statusFilter").value;
        const department = document.getElementById("departmentFilter").value;

        let result = users.filter(u => {
            const matchesSearch = !search || u.name.toLowerCase().includes(search) || u.email.toLowerCase().includes(search) || u.role.toLowerCase().includes(search) || u.department.toLowerCase().includes(search);
            return matchesSearch && (!role || u.role === role) && (!status || u.status === status) && (!department || u.department === department);
        });

        if (sortCol) {
            result = [...result].sort((a, b) => {
                let av = a[sortCol]; let bv = b[sortCol];
                if (typeof av === "string") av = av.toLowerCase();
                if (typeof bv === "string") bv = bv.toLowerCase();
                if (av < bv) return sortDir === "asc" ? -1 : 1;
                if (av > bv) return sortDir === "asc" ? 1 : -1;
                return 0;
            });
        }
        return result;
    }

    function renderStats() {
        document.getElementById("totalUsersCount").textContent = users.length;
        document.getElementById("activeUsersCount").textContent = users.filter(u => u.status === "Active").length;
        document.getElementById("adminUsersCount").textContent = users.filter(u => u.role === "Administrator").length;
        document.getElementById("assignedTicketCount").textContent = users.reduce((sum, u) => sum + u.assignedTickets, 0);
    }

    // ===== RENDER MOBILE CARDS =====
    function renderMobileCards(filtered) {
        const container = document.getElementById("mCardList");
        const emptyMobile = document.getElementById("emptyStateMobile");
        container.innerHTML = "";

        if (!filtered.length) { emptyMobile.style.display = "block"; return; }
        emptyMobile.style.display = "none";

        filtered.forEach(u => {
            const card = document.createElement("div");
            card.className = `m-user-card${u.id === selectedUserId ? " selected" : ""}`;
            card.innerHTML = `
                <div class="m-user-top">
                    <div class="avatar ${u.avClass}" style="width:38px;height:38px;font-size:12px;flex-shrink:0;">${u.initials}</div>
                    <div class="m-user-info">
                        <div class="m-user-name">${u.name}</div>
                        <div class="m-user-email">${u.email}</div>
                    </div>
                    <span class="badge badge-${badgeClass(u.status)}" style="flex-shrink:0;">${u.status}</span>
                </div>
                <div class="m-user-badges">
                    <span class="badge badge-${badgeClass(u.role)}">${u.role}</span>
                    <span style="font-size:11px;color:var(--muted);">${u.department}</span>
                </div>
                <div class="m-user-footer">
                    <div class="m-user-stats">
                        <span><strong>${u.assignedTickets}</strong> assigned</span>
                        <span><strong>${u.resolvedTickets}</strong> resolved</span>
                    </div>
                    <div class="m-user-actions">
                        <button class="btn btn-ghost btn-icon btn-sm m-edit-btn" data-id="${u.id}" title="Edit" type="button">
                            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 013 3L7 19l-4 1 1-4z"/></svg>
                        </button>
                        <button class="btn btn-ghost btn-icon btn-sm m-delete-btn" data-id="${u.id}" title="Remove" type="button" style="color:var(--danger);opacity:0.7;">
                            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg>
                        </button>
                    </div>
                </div>
            `;
            card.addEventListener("click", e => {
                if (e.target.closest(".m-edit-btn") || e.target.closest(".m-delete-btn")) return;
                selectedUserId = u.id;
                renderUsers();
                setTimeout(() => document.getElementById("userDetail").scrollIntoView({ behavior: "smooth", block: "start" }), 60);
            });
            container.appendChild(card);
        });

        container.querySelectorAll(".m-edit-btn").forEach(btn => btn.addEventListener("click", e => { e.stopPropagation(); openEditModal(btn.dataset.id); }));
        container.querySelectorAll(".m-delete-btn").forEach(btn => btn.addEventListener("click", e => { e.stopPropagation(); openDeleteModal(btn.dataset.id); }));
    }

    // ===== RENDER USERS =====
    function renderUsers() {
        renderStats();
        const filtered = getFilteredUsers();
        const tbody = document.getElementById("userTableBody");
        const empty = document.getElementById("emptyState");

        document.getElementById("resultCount").textContent = `${filtered.length} user${filtered.length === 1 ? "" : "s"}`;

        if (!filtered.length) {
            tbody.innerHTML = "";
            empty.style.display = "block";
            renderMobileCards([]);
            renderUserDetail(null);
            return;
        }

        empty.style.display = "none";
        if (!filtered.some(u => u.id === selectedUserId)) selectedUserId = filtered[0].id;

        tbody.innerHTML = filtered.map(u => `
            <tr class="${u.id === selectedUserId ? "selected" : ""}" onclick="selectUser('${u.id}')">
                <td>
                    <div class="user-name-cell">
                        <div class="avatar avatar-sm ${u.avClass}">${u.initials}</div>
                        <div class="user-main">
                            <strong>${u.name}</strong>
                            <span>${u.email}</span>
                        </div>
                    </div>
                </td>
                <td><span class="badge badge-${badgeClass(u.role)}">${u.role}</span></td>
                <td><span class="badge badge-${badgeClass(u.status)}">${u.status}</span></td>
                <td>${u.department}</td>
                <td style="font-family:var(--font-mono);">${u.assignedTickets}</td>
                <td style="font-family:var(--font-mono);">${u.resolvedTickets}</td>
                <td style="color:var(--muted);font-size:12px;">${u.lastActive}</td>
                <td>
                    <div class="row-actions">
                        <button class="btn btn-ghost btn-icon" title="Edit" onclick="event.stopPropagation(); openEditModal('${u.id}')">
                            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 013 3L7 19l-4 1 1-4z"/></svg>
                        </button>
                        <button class="btn btn-ghost btn-icon" title="Remove" onclick="event.stopPropagation(); openDeleteModal('${u.id}')">
                            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg>
                        </button>
                    </div>
                </td>
            </tr>
        `).join("");

        renderMobileCards(filtered);
        renderUserDetail(users.find(u => u.id === selectedUserId));
    }

    function selectUser(id) { selectedUserId = id; renderUsers(); }

    function renderUserDetail(u) {
        const detail = document.getElementById("userDetail");
        const activityId = document.getElementById("activityUserId");
        const activitySubtitle = document.getElementById("activitySubtitle");
        const activityList = document.getElementById("activityList");

        if (!u) {
            detail.innerHTML = `<div style="color:var(--muted);font-size:13px;text-align:center;padding:20px 0;">Select a user to view details</div>`;
            activityId.textContent = "—";
            activitySubtitle.textContent = "Select a user to view recent activity.";
            activityList.innerHTML = "";
            return;
        }

        detail.innerHTML = `
            <div class="detail-header">
                <div style="display:flex;align-items:flex-start;gap:12px;">
                    <div class="avatar ${u.avClass}" style="width:44px;height:44px;font-size:13px;">${u.initials}</div>
                    <div>
                        <h2>${u.name}</h2>
                        <p style="font-family:var(--font-mono);font-size:12px;">${u.email}</p>
                    </div>
                </div>
                <span class="badge badge-${badgeClass(u.status)}">${u.status}</span>
            </div>
            <p>${u.name} is a ${u.role.toLowerCase()} on the BugTrack demo team. This profile shows permissions, assignment load, and recent activity for the portfolio demo.</p>
            <div class="detail-meta">
                <div class="detail-meta-item"><strong>User ID</strong>${u.id}</div>
                <div class="detail-meta-item"><strong>Role</strong>${u.role}</div>
                <div class="detail-meta-item"><strong>Department</strong>${u.department}</div>
                <div class="detail-meta-item"><strong>Joined</strong>${u.joined}</div>
            </div>
            <div class="user-mini-grid">
                <div class="user-mini-stat"><strong>${u.assignedTickets}</strong><span>Assigned</span></div>
                <div class="user-mini-stat"><strong>${u.resolvedTickets}</strong><span>Resolved</span></div>
                <div class="user-mini-stat"><strong>${u.openCritical}</strong><span>Critical</span></div>
            </div>
            <div class="detail-actions">
                <button class="btn btn-secondary btn-sm" onclick="openEditModal('${u.id}')">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 013 3L7 19l-4 1 1-4z"/></svg>
                    Edit User
                </button>
                <button class="btn btn-secondary btn-sm" onclick="toggleUserStatus('${u.id}')">
                    ${u.status === "Inactive" ? "Reactivate" : "Mark Inactive"}
                </button>
                <button class="btn btn-danger btn-sm" onclick="openDeleteModal('${u.id}')">Remove</button>
            </div>
        `;

        activityId.textContent = u.id;
        activitySubtitle.textContent = `${u.name}'s recent workspace activity.`;
        activityList.innerHTML = u.activity.map((item, i) => `
            <div class="activity-item" style="animation-delay:${i * 0.04}s">
                <div class="activity-dot"></div>
                <div><h4>${item}</h4><span>${u.lastActive}</span></div>
            </div>
        `).join("");
    }

    // ===== CREATE =====
    function openCreateModal() {
        document.getElementById("createName").value = "";
        document.getElementById("createEmail").value = "";
        document.getElementById("createRole").value = "Developer";
        document.getElementById("createStatus").value = "Active";
        document.getElementById("createDepartment").value = "Engineering";
        openModal("createModal");
        setTimeout(() => document.getElementById("createName").focus(), 80);
    }

    document.getElementById("openCreateModal").addEventListener("click", openCreateModal);

    document.getElementById("submitCreate").addEventListener("click", () => {
        const name = document.getElementById("createName").value.trim();
        const email = document.getElementById("createEmail").value.trim();
        if (!name || !email) { toast("Please enter a name and email.", "error"); return; }
        const initials = getInitials(name);
        const user = {
            id: `USR-${String(nextUserNumber++).padStart(3, "0")}`,
            name, email, initials, avClass: getAvClass(initials),
            role: document.getElementById("createRole").value,
            status: document.getElementById("createStatus").value,
            department: document.getElementById("createDepartment").value,
            assignedTickets: 0, resolvedTickets: 0, openCritical: 0,
            lastActive: "Just now", joined: "May 2026",
            activity: [`User added by ${currentUserName}.`, `${name} was assigned the ${document.getElementById("createRole").value} role.`]
        };
        users.unshift(user);
        selectedUserId = user.id;
        closeModal("createModal");
        renderUsers();
        toast("User added successfully.", "success");
    });

    // ===== EDIT =====
    function openEditModal(id) {
        const u = users.find(x => x.id === id);
        if (!u) return;
        editingUserId = id;
        document.getElementById("editModalId").textContent = u.id;
        document.getElementById("editName").value = u.name;
        document.getElementById("editEmail").value = u.email;
        document.getElementById("editRole").value = u.role;
        document.getElementById("editStatus").value = u.status;
        document.getElementById("editDepartment").value = u.department;
        openModal("editModal");
        setTimeout(() => document.getElementById("editName").focus(), 80);
    }

    document.getElementById("submitEdit").addEventListener("click", () => {
        const u = users.find(x => x.id === editingUserId);
        if (!u) return;
        const name = document.getElementById("editName").value.trim();
        const email = document.getElementById("editEmail").value.trim();
        if (!name || !email) { toast("Please enter a name and email.", "error"); return; }
        const oldRole = u.role; const oldStatus = u.status;
        const initials = getInitials(name);
        u.name = name; u.email = email; u.initials = initials; u.avClass = getAvClass(initials);
        u.role = document.getElementById("editRole").value;
        u.status = document.getElementById("editStatus").value;
        u.department = document.getElementById("editDepartment").value;
        u.lastActive = "Just now";
        if (oldRole !== u.role) u.activity.push(`Role changed from ${oldRole} to ${u.role}.`);
        if (oldStatus !== u.status) u.activity.push(`Status changed from ${oldStatus} to ${u.status}.`);
        u.activity.push(`User profile updated by ${currentUserName}.`);
        closeModal("editModal");
        renderUsers();
        toast("User saved.", "success");
    });

    function toggleUserStatus(id) {
        const u = users.find(x => x.id === id);
        if (!u) return;
        const oldStatus = u.status;
        u.status = u.status === "Inactive" ? "Active" : "Inactive";
        u.lastActive = "Just now";
        u.activity.push(`Status changed from ${oldStatus} to ${u.status}.`);
        renderUsers();
        toast(`User marked ${u.status.toLowerCase()}.`, "info");
    }

    // ===== DELETE =====
    function openDeleteModal(id) {
        const u = users.find(x => x.id === id);
        if (!u) return;
        deletingUserId = id;
        document.getElementById("deleteUserName").textContent = u.name;
        openModal("deleteModal");
    }

    document.getElementById("confirmDelete").addEventListener("click", () => {
        users = users.filter(u => u.id !== deletingUserId);
        if (selectedUserId === deletingUserId) selectedUserId = users[0]?.id || null;
        closeModal("deleteModal");
        renderUsers();
        toast("User removed.", "info");
    });

    // ===== EXPORT =====
    document.getElementById("exportBtn").addEventListener("click", () => {
        document.getElementById("exportCount").textContent = getFilteredUsers().length;
        openModal("exportModal");
    });

    document.getElementById("confirmExport").addEventListener("click", () => {
        const format = document.getElementById("exportFormat").value;
        const filtered = getFilteredUsers();
        let content = "", mime = "text/plain";
        if (format === "json") {
            content = JSON.stringify(filtered, null, 2); mime = "application/json";
        } else {
            const delimiter = format === "tsv" ? "\t" : ",";
            const headers = ["ID","Name","Email","Role","Status","Department","Assigned Tickets","Resolved Tickets","Last Active"];
            const rows = filtered.map(u => [u.id,u.name,u.email,u.role,u.status,u.department,u.assignedTickets,u.resolvedTickets,u.lastActive]);
            content = [headers, ...rows].map(row => row.map(cell => `"${String(cell).replaceAll('"','""')}"`).join(delimiter)).join("\n");
            mime = format === "csv" ? "text/csv" : "text/tab-separated-values";
        }
        const blob = new Blob([content], { type: mime });
        const a = document.createElement("a"); a.href = URL.createObjectURL(blob);
        a.download = `bugtrack-users.${format}`; a.click();
        URL.revokeObjectURL(a.href);
        closeModal("exportModal");
        toast("Users exported.", "success");
    });

    // ===== FILTER LISTENERS =====
    ["topSearch","roleFilter","statusFilter","departmentFilter"].forEach(id => {
        const el = document.getElementById(id);
        el.addEventListener("input", renderUsers);
        el.addEventListener("change", renderUsers);
    });

    document.getElementById("clearFilters").addEventListener("click", () => {
        document.getElementById("topSearch").value = "";
        document.getElementById("mobileSearchInput").value = "";
        document.getElementById("roleFilter").value = "";
        document.getElementById("statusFilter").value = "";
        document.getElementById("departmentFilter").value = "";
        renderUsers();
        toast("Filters cleared.", "info");
    });

    // ===== SORT =====
    document.querySelectorAll("thead th[data-sort]").forEach(th => {
        th.addEventListener("click", () => {
            const col = th.dataset.sort;
            if (sortCol === col) { sortDir = sortDir === "asc" ? "desc" : "asc"; } else { sortCol = col; sortDir = "asc"; }
            document.querySelectorAll("thead th[data-sort]").forEach(x => x.classList.remove("asc","desc"));
            th.classList.add(sortDir);
            renderUsers();
        });
    });

    // ===== MOBILE SIDEBAR =====
    const sidebar = document.getElementById("sidebar");
    const mobileBackdrop = document.getElementById("mobileBackdrop");

    function closeMobileSidebar() {
        sidebar.classList.remove("open");
        mobileBackdrop.classList.remove("show");
        mobileBackdrop.style.left = "0";
        document.body.style.overflow = "";
    }
    function openMobileSidebar() {
        sidebar.classList.add("open");
        mobileBackdrop.classList.add("show");
        const sidebarW = sidebar.getBoundingClientRect().width;
        mobileBackdrop.style.left = sidebarW + "px";
        document.body.style.overflow = "hidden";
    }

    document.getElementById("mobileMenu").addEventListener("click", () => {
        sidebar.classList.contains("open") ? closeMobileSidebar() : openMobileSidebar();
    });
    mobileBackdrop.addEventListener("click", closeMobileSidebar);
    sidebar.querySelectorAll("a.nav-item").forEach(a => a.addEventListener("click", closeMobileSidebar));

    // ===== BOTTOM NAV =====
    document.getElementById("bnUsers").addEventListener("click", () => {
        document.querySelectorAll(".bottom-nav-item").forEach(b => b.classList.remove("active"));
        document.getElementById("bnUsers").classList.add("active");
    });
    document.getElementById("bnAddUser").addEventListener("click", openCreateModal);
    document.getElementById("bnSearch").addEventListener("click", openMobileSearch);
    document.getElementById("bnMenu").addEventListener("click", () => {
        sidebar.classList.contains("open") ? closeMobileSidebar() : openMobileSidebar();
    });

    // ===== ADMIN LINK =====
    const adminHomeLink = document.getElementById("adminHomeLink");
    if (adminHomeLink) {
        adminHomeLink.addEventListener("click", () => { window.location.href = adminHomeLink.dataset.url; });
        adminHomeLink.addEventListener("keydown", e => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); adminHomeLink.click(); } });
    }

    // ===== LOGOUT =====
    document.getElementById("logoutBtn")?.addEventListener("click", async (e) => {
        e.stopPropagation();
        if (!confirm("Sign out of the BugTrack demo?")) return;
        try {
            const response = await fetch(logoutUrl, { method: "POST" });
            const result = await response.json();
            window.location.href = result.redirectUrl || homeUrl;
        } catch { window.location.href = homeUrl; }
    });

    renderUsers();
</script>
</body>
</html>
