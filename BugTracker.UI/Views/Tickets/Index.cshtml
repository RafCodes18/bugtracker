<!-- ===== EXPORT MODAL ===== -->
<div class="modal-backdrop" id="exportModal">
    <div class="modal-card modal-sm">
        <div class="modal-header">
            <h2>Export Tickets</h2>
            <button class="btn btn-ghost btn-sm" data-close="exportModal">
