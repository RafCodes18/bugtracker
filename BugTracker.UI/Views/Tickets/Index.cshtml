            <button class="btn btn-secondary" data-close="deleteModal">Cancel</button>
            <button class="btn btn-danger" id="confirmDelete">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg>
                Delete Ticket
            </button>
        </div>
    </div>
</div>

<!-- ===== STATUS CHANGE MODAL ===== -->
<div class="modal-backdrop" id="statusModal">
    <div class="modal-card modal-sm">
        <div class="modal-header">
            <h2>Change Status</h2>
            <button class="btn btn-ghost btn-sm" data-close="statusModal">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="modal-body">
            <p style="color:var(--muted);font-size:13px;margin-bottom:4px;">Select the new status for <strong id="statusModalTicketTitle" style="color:var(--text);"></strong></p>
            <div class="status-grid" id="statusGrid">
                <div class="status-option" data-value="Open">
                    <span class="badge badge-open" style="font-size:12px;">Open</span>
                    <div class="status-name">Open</div>
                    <div class="status-desc">Newly reported, not yet assigned</div>
                </div>
                <div class="status-option" data-value="In Progress">
                    <span class="badge badge-progress" style="font-size:12px;">In Progress</span>
                    <div class="status-name">In Progress</div>
                    <div class="status-desc">Actively being worked on</div>
                </div>
                <div class="status-option" data-value="Review">
                    <span class="badge badge-review" style="font-size:12px;">Review</span>
                    <div class="status-name">Review</div>
                    <div class="status-desc">Awaiting code review or QA</div>
                </div>
                <div class="status-option" data-value="Resolved">
                    <span class="badge badge-resolved" style="font-size:12px;">Resolved</span>
                    <div class="status-name">Resolved</div>
                    <div class="status-desc">Fixed and verified</div>
                </div>
            </div>
        </div>
        <div class="modal-actions">
            <button class="btn btn-secondary" data-close="statusModal">Cancel</button>
            <button class="btn btn-primary" id="confirmStatusChange">Apply Status</button>
        </div>
    </div>
</div>

