<!-- ===== CREATE MODAL ===== -->
<div class="modal-backdrop" id="createModal">
    <div class="modal-card">
        <div class="modal-header">
            <h2>Create Ticket</h2>
                <button class="btn btn-ghost btn-sm" data-ph="bt_create_ticket_click" data-close="createModal">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                Close
            </button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="form-label" for="createTitle">Title</label>
                <input class="form-control" id="createTitle" type="text" placeholder="e.g. Login timeout not clearing session data" required />
            </div>
            <div class="form-group">
                <label class="form-label" for="createDescription">Description</label>
                <textarea class="form-control" id="createDescription" placeholder="Describe the issue, expected behavior, steps to reproduce…" required></textarea>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label" for="createType">Type</label>
                    <select class="form-control" id="createType">
                        <option value="Bug">Bug</option>
                        <option value="Feature">Feature</option>
                        <option value="Task">Task</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="createStatus">Status</label>
                    <select class="form-control" id="createStatus">
                        <option value="Open">Open</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Review">Review</option>
                        <option value="Resolved">Resolved</option>
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label" for="createPriority">Priority</label>
                    <select class="form-control" id="createPriority">
                        <option value="Critical">Critical</option>
                        <option value="High">High</option>
                        <option value="Medium" selected>Medium</option>
                        <option value="Low">Low</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="createAssignee">Assignee</label>
                    <select class="form-control" id="createAssignee">
                        <option value="Rafael Parra">Rafael Parra</option>
                        <option value="M. Chen">M. Chen</option>
                        <option value="S. Patel">S. Patel</option>
                        <option value="T. Kowalski">T. Kowalski</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="modal-actions">
            <button class="btn btn-secondary" data-close="createModal">Cancel</button>
            <button class="btn btn-primary" id="submitCreate">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Create Ticket
            </button>
        </div>
    </div>
</div>

<!-- ===== EDIT MODAL ===== -->
<div class="modal-backdrop" id="editModal">
    <div class="modal-card">
        <div class="modal-header">
            <div>
                <h2>Edit Ticket</h2>
                <div class="modal-header-meta">
                    <span class="ticket-id" id="editModalId" style="font-family:var(--font-mono);font-size:12px;color:var(--muted);"></span>
                </div>
            </div>
            <button class="btn btn-ghost btn-sm" data-close="editModal">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                Close
            </button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="form-label" for="editTitle">Title</label>
                <input class="form-control" id="editTitle" type="text" required />
            </div>
            <div class="form-group">
                <label class="form-label" for="editDescription">Description</label>
                <textarea class="form-control" id="editDescription" required></textarea>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label" for="editType">Type</label>
                    <select class="form-control" id="editType">
                        <option value="Bug">Bug</option>
                        <option value="Feature">Feature</option>
                        <option value="Task">Task</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="editStatus">Status</label>
                    <select class="form-control" id="editStatus">
                        <option value="Open">Open</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Review">Review</option>
                        <option value="Resolved">Resolved</option>
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label" for="editPriority">Priority</label>
                    <select class="form-control" id="editPriority">
                        <option value="Critical">Critical</option>
                        <option value="High">High</option>
                        <option value="Medium">Medium</option>
                        <option value="Low">Low</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="editAssignee">Assignee</label>
                    <select class="form-control" id="editAssignee">
                        <option value="Rafael Parra">Rafael Parra</option>
                        <option value="M. Chen">M. Chen</option>
                        <option value="S. Patel">S. Patel</option>
                        <option value="T. Kowalski">T. Kowalski</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="modal-actions">
                <button class="btn btn-danger btn-sm" data-ph="bt_edit_delete_click" id="editDeleteBtn">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                Delete
            </button>
            <button class="btn btn-secondary" data-close="editModal">Cancel</button>
            <button class="btn btn-primary" data-ph="bt_update_ticket" id="submitEdit">Save Changes</button>
        </div>
    </div>
</div>

<!-- ===== DELETE CONFIRM MODAL ===== -->
<div class="modal-backdrop" id="deleteModal">
    <div class="modal-card modal-sm">
        <div class="delete-modal-body">
            <div class="delete-icon">
                <svg width="22" height="22" fill="none" stroke="#ff4f6a" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
