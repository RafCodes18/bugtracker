@using System.Text.Json
@using Microsoft.AspNetCore.Http
@model List<BugTracker.UI.Models.Ticket>

@functions {
    string RelativeTime(DateTime date)
    {
        var diff = DateTime.UtcNow - date;

        if (diff.TotalMinutes < 2) return "Just now";
        if (diff.TotalHours < 24) return "Today";
        if (diff.TotalDays < 2) return "Yesterday";
        return $"{Math.Floor(diff.TotalDays)} days ago";
    }
}

@{
    Layout = null;

    var ticketsJson = JsonSerializer.Serialize(Model.Select(t => new
    {
        dbId = t.Id,
        id = $"#{1000 + t.Id}",
        title = t.Title,
        description = t.Description,
        type = t.Type,
        status = t.Status,
        priority = t.Priority,
        assignee = t.Assignee,
        initials = t.Initials,
        avClass = t.AvatarClass,
        updated = RelativeTime(t.UpdatedAt),
        activity = t.Activities
            .OrderBy(a => a.CreatedAt)
            .Select(a => a.Message)
            .ToList()
    }));

    var currentUserName = Context.Session.GetString("DemoUserName") ?? "Rafael Parra";
    var currentUserRole = Context.Session.GetString("DemoUserRole") ?? "Administrator";
    var currentUserInitials = Context.Session.GetString("DemoUserInitials") ?? "RP";
    var currentUserAvatarClass = Context.Session.GetString("DemoUserAvatarClass") ?? "av-rp";
}
