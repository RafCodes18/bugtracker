    <script>
        (function () {
            function capture(name, props = {}) {
                if (!window.posthog) return;

                posthog.capture(name, {
                    app: "BugTracker",
                    path: window.location.pathname,
                    title: document.title,
                    referrer: document.referrer || null,
                    viewport: `${window.innerWidth}x${window.innerHeight}`,
                    ...props
                });
            }

            document.addEventListener("DOMContentLoaded", function () {
                capture("bt_page_ready");
            });

            document.addEventListener("click", function (e) {
                const el = e.target.closest("[data-ph], a, button");

                if (!el) return;

                capture(el.dataset.ph || "bt_click", {
                    text: (el.innerText || el.getAttribute("aria-label") || "").trim().slice(0, 100),
                    href: el.href || null,
                    id: el.id || null,
                    classes: el.className || null
                });
            }, true);

            document.addEventListener("submit", function (e) {
                capture("bt_form_submit", {
                    formId: e.target.id || null,
                    action: e.target.action || null
                });
            }, true);

            window.addEventListener("error", function (e) {
                capture("bt_js_error", {
                    message: e.message,
                    source: e.filename,
                    line: e.lineno
                });
            });
        })();
    </script>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #080d1a;
            --bg-soft: #0d1525;
            --card: #0f1b30;
            --card-light: #162035;
            --glass: rgba(15, 27, 48, 0.85);
            --text: #eef2ff;
            --muted: #8896b3;
            --faint: rgba(255,255,255,0.04);
            --accent: #4fffb0;
            --accent-2: #4d9eff;
            --accent-3: #b06eff;
            --border: rgba(255,255,255,0.08);
            --border-strong: rgba(255,255,255,0.15);
            --shadow: 0 32px 80px rgba(0,0,0,0.5);
            --shadow-sm: 0 4px 20px rgba(0,0,0,0.35);
            --radius: 16px;
            --radius-sm: 10px;
            --sidebar-w: 248px;
            --header-h: 64px;
            --success: #4fffb0;
            --warning: #fbbf24;
            --danger: #ff4f6a;
            --info: #4d9eff;
            --purple: #b06eff;
            --font-display: 'Syne', sans-serif;
            --font-body: 'DM Sans', sans-serif;
            --font-mono: 'DM Mono', monospace;
        }

        html, body {
            min-height: 100%;
            font-family: var(--font-body);
            font-size: 14px;
            color: var(--text);
            background: var(--bg);
            line-height: 1.6;
            overflow-x: hidden;
            max-width: 100vw;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse 80% 50% at 10% 0%, rgba(77,158,255,0.12) 0%, transparent 60%),
                radial-gradient(ellipse 60% 40% at 90% 10%, rgba(79,255,176,0.08) 0%, transparent 50%),
                radial-gradient(ellipse 50% 60% at 60% 80%, rgba(176,110,255,0.06) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
        }

        body > * { position: relative; z-index: 1; }

        a { color: inherit; text-decoration: none; }
        button, input, select, textarea { font: inherit; }

        /* ===== UTILITIES ===== */
        .hidden { display: none !important; }
        .truncate { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .text-muted { color: var(--muted); }

        /* ===== SCROLLBAR ===== */
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 999px; }

        /* ===== BUTTONS ===== */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            padding: 9px 16px;
            border-radius: var(--radius-sm);
            border: 1px solid transparent;
            font-weight: 600;
            font-family: var(--font-body);
            cursor: pointer;
            transition: all 0.18s ease;
            white-space: nowrap;
            background: transparent;
            color: var(--text);
            font-size: 13.5px;
            letter-spacing: -0.01em;
            -webkit-tap-highlight-color: transparent;
        }
        .btn:hover { transform: translateY(-1px); }
        .btn:active { transform: translateY(0); }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-2) 100%);
            color: #030810;
            font-weight: 700;
            border: none;
            box-shadow: 0 0 24px rgba(79,255,176,0.18);
        }
        .btn-primary:hover { box-shadow: 0 0 32px rgba(79,255,176,0.28); }

        .btn-secondary {
            background: rgba(255,255,255,0.05);
            color: var(--text);
            border-color: var(--border-strong);
        }
        .btn-secondary:hover { background: rgba(255,255,255,0.09); border-color: rgba(255,255,255,0.22); }

        .btn-danger {
            background: rgba(255,79,106,0.12);
            color: #ff7a92;
            border-color: rgba(255,79,106,0.25);
        }
        .btn-danger:hover { background: rgba(255,79,106,0.2); }

        .btn-ghost {
            color: var(--muted);
            border-color: transparent;
            padding: 7px 10px;
            border-radius: 8px;
        }
        .btn-ghost:hover { color: var(--text); background: rgba(255,255,255,0.06); }

        .btn-sm { padding: 6px 12px; font-size: 12.5px; }
        .btn-icon { padding: 7px; }
        .btn:focus-visible { outline: 2px solid rgba(79,255,176,0.5); outline-offset: 2px; }

        /* ===== BADGES ===== */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 9px;
            border-radius: 999px;
            font-size: 11.5px;
            font-weight: 600;
            white-space: nowrap;
            border: 1px solid transparent;
            letter-spacing: 0.01em;
        }
        .badge::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; opacity: 0.7; }

        .badge-open { color: #93c5fd; background: rgba(96,165,250,0.1); border-color: rgba(96,165,250,0.2); }
        .badge-progress { color: #fde68a; background: rgba(251,191,36,0.1); border-color: rgba(251,191,36,0.2); }
        .badge-review { color: #c4b5fd; background: rgba(167,139,250,0.1); border-color: rgba(167,139,250,0.2); }
        .badge-resolved { color: var(--accent); background: rgba(79,255,176,0.08); border-color: rgba(79,255,176,0.2); }
        .badge-critical { color: #fca5a5; background: rgba(255,79,106,0.12); border-color: rgba(255,79,106,0.25); }
        .badge-high { color: #fca5a5; background: rgba(255,79,106,0.08); border-color: rgba(255,79,106,0.18); }
        .badge-medium { color: #fde68a; background: rgba(251,191,36,0.1); border-color: rgba(251,191,36,0.2); }
        .badge-low { color: #86efac; background: rgba(34,197,94,0.08); border-color: rgba(34,197,94,0.18); }
        .badge-bug { color: #e879f9; background: rgba(232,121,249,0.1); border-color: rgba(232,121,249,0.2); }
        .badge-feature { color: #93c5fd; background: rgba(96,165,250,0.1); border-color: rgba(96,165,250,0.2); }
        .badge-task { color: var(--muted); background: rgba(255,255,255,0.04); border-color: var(--border); }

        /* ===== GLASS CARD ===== */
        .card {
            background: var(--glass);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            backdrop-filter: blur(20px);
            box-shadow: var(--shadow-sm);
        }

        /* ===== SIDEBAR ===== */
        .app-layout { display: flex; min-height: 100vh; width: 100%; overflow-x: hidden; }

        .sidebar {
            width: var(--sidebar-w);
            background: rgba(8,13,26,0.92);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0; left: 0;
            height: 100vh;
            z-index: 200;
            backdrop-filter: blur(24px);
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 18px 20px;
            border-bottom: 1px solid var(--border);
        }

        .logo-mark {
            width: 34px; height: 34px;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            color: #030810;
            border-radius: 10px;
            display: grid;
            place-items: center;
            font-weight: 900;
            font-size: 12px;
            font-family: var(--font-display);
            letter-spacing: -0.03em;
            flex-shrink: 0;
        }

        .logo-text {
            font-family: var(--font-display);
            font-weight: 900;
            letter-spacing: -0.05em;
            font-size: 1.2rem;
        }
        .logo-text span { color: var(--accent); }

        .sidebar-nav { flex: 1; padding: 12px 10px; overflow-y: auto; }

        .nav-section-label {
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            padding: 10px 10px 5px;
            font-family: var(--font-mono);
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 11px;
            border-radius: var(--radius-sm);
            color: var(--muted);
            font-size: 13.5px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.15s ease;
            margin-bottom: 2px;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
        }
        .nav-item:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .nav-item.active {
            color: #030810;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            font-weight: 700;
        }
        .nav-item svg { flex-shrink: 0; }

        .nav-badge {
            margin-left: auto;
            background: rgba(255,79,106,0.85);
            color: #fff;
            border-radius: 999px;
            padding: 1px 7px;
            font-size: 10.5px;
            font-weight: 700;
            min-width: 20px;
            text-align: center;
            font-family: var(--font-mono);
        }
        .nav-item.active .nav-badge { background: rgba(3,8,16,0.25); color: #030810; }

        button.nav-item { width: 100%; border: none; background: transparent; text-align: left; }

        .sidebar-footer { padding: 12px; border-top: 1px solid var(--border); }

        .user-block {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 10px;
            border-radius: 12px;
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border);
        }

        .avatar {
            width: 32px; height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(79,255,176,0.15), rgba(77,158,255,0.15));
            color: var(--accent);
            border: 1px solid rgba(79,255,176,0.25);
            display: grid;
            place-items: center;
            font-weight: 700;
            font-size: 11px;
            flex-shrink: 0;
            font-family: var(--font-mono);
        }
        .avatar-sm { width: 26px; height: 26px; font-size: 10px; }

        .av-rp { background: linear-gradient(135deg, rgba(79,255,176,0.15), rgba(77,158,255,0.15)); color: var(--accent); border-color: rgba(79,255,176,0.25); }
        .av-mc { background: linear-gradient(135deg, rgba(77,158,255,0.15), rgba(176,110,255,0.15)); color: var(--accent-2); border-color: rgba(77,158,255,0.25); }
        .av-sp { background: linear-gradient(135deg, rgba(176,110,255,0.15), rgba(232,121,249,0.15)); color: var(--accent-3); border-color: rgba(176,110,255,0.25); }
        .av-tk { background: linear-gradient(135deg, rgba(251,191,36,0.15), rgba(255,79,106,0.15)); color: #fbbf24; border-color: rgba(251,191,36,0.25); }

        /* ===== MAIN ===== */
        .main-content { margin-left: var(--sidebar-w); flex: 1; min-height: 100vh; min-width: 0; max-width: 100%; overflow-x: hidden; }

        .page-header {
            height: var(--header-h);
            padding: 0 28px;
            background: rgba(8,13,26,0.75);
            border-bottom: 1px solid var(--border);
            backdrop-filter: blur(20px);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            position: sticky;
            top: 0;
            z-index: 50;
            width: 100%;
            box-sizing: border-box;
            overflow: hidden;
        }

        .page-header-left { display: flex; align-items: center; gap: 12px; }
        .mobile-menu { display: none; }

        .page-header h1 {
            font-size: 1.2rem;
            font-weight: 900;
            letter-spacing: -0.05em;
            font-family: var(--font-display);
        }

        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--muted);
            margin-top: 1px;
        }
        .breadcrumb span { color: var(--text); font-weight: 600; }

        .page-actions { display: flex; align-items: center; gap: 10px; }
        .page-body { padding: 24px 28px; }

        /* Mobile search toggle — hidden on desktop */
        #mobileSearchToggle { display: none; }

        /* ===== SEARCH ===== */
        .search-bar {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 8px 12px;
            width: 300px;
            transition: all 0.15s ease;
        }
        .search-bar:focus-within {
            border-color: rgba(79,255,176,0.4);
            box-shadow: 0 0 0 3px rgba(79,255,176,0.07);
            background: rgba(255,255,255,0.06);
        }
        .search-bar input { border: none; outline: none; background: transparent; color: var(--text); width: 100%; }
        .search-bar input::placeholder { color: var(--muted); }

        /* Floating mobile search */
        .mobile-search-bar {
            display: none;
            position: fixed;
            top: calc(var(--header-h) + 6px);
            left: 12px;
            right: 12px;
            z-index: 60;
            align-items: center;
            gap: 8px;
            padding: 10px 14px;
            background: rgba(13,21,37,0.98);
            border: 1px solid var(--border-strong);
            border-radius: var(--radius-sm);
            box-shadow: var(--shadow);
            backdrop-filter: blur(20px);
        }
        .mobile-search-bar.open { display: flex; animation: fadeInDown 0.18s ease; }
        @@keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-8px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .mobile-search-bar input {
            flex: 1;
            border: none;
            background: transparent;
            color: var(--text);
            outline: none;
            font-size: 15px;
        }
        .mobile-search-bar input::placeholder { color: var(--muted); }

        /* ===== STATS ===== */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px;
            margin-bottom: 22px;
        }

        .stat-card {
            background: var(--glass);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 18px 20px;
            backdrop-filter: blur(20px);
            position: relative;
            overflow: hidden;
            transition: border-color 0.2s ease;
        }
        .stat-card:hover { border-color: var(--border-strong); }

        .stat-label {
            font-size: 11px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-family: var(--font-mono);
        }
        .stat-value {
            font-size: 2.4rem;
            font-weight: 900;
            letter-spacing: -0.07em;
            line-height: 1;
            margin-top: 6px;
            font-family: var(--font-display);
        }
        .stat-sub { font-size: 11.5px; color: var(--muted); margin-top: 5px; }
        .stat-up { color: var(--success); font-weight: 700; }
        .stat-down { color: var(--danger); font-weight: 700; }

        /* ===== FILTER BAR ===== */
        .filter-bar {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 14px;
        }

        .filter-select {
            padding: 8px 12px;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            color: var(--text);
            background: rgba(255,255,255,0.04);
            cursor: pointer;
            outline: none;
            font-size: 13px;
            font-family: var(--font-body);
            transition: all 0.15s ease;
        }
        .filter-select:focus { border-color: rgba(79,255,176,0.4); }
        .filter-select option { background: #0d1525; color: var(--text); }

        .result-count {
            margin-left: auto;
            font-size: 12px;
            color: var(--muted);
            font-family: var(--font-mono);
        }

        /* ===== TABLE ===== */
        .table-wrap {
            overflow-x: auto;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            background: var(--glass);
            backdrop-filter: blur(20px);
            box-shadow: var(--shadow-sm);
        }

        table { width: 100%; border-collapse: collapse; min-width: 900px; }

        thead th {
            padding: 11px 16px;
            text-align: left;
            font-size: 10.5px;
            font-weight: 700;
            color: var(--muted);
            background: rgba(255,255,255,0.025);
            border-bottom: 1px solid var(--border);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-family: var(--font-mono);
        }

        thead th[data-sort] { cursor: pointer; user-select: none; }
        thead th[data-sort]:hover { color: var(--text); }
        thead th[data-sort]::after { content: ' ↕'; opacity: 0.35; }
        thead th[data-sort].asc::after { content: ' ↑'; opacity: 1; color: var(--accent); }
        thead th[data-sort].desc::after { content: ' ↓'; opacity: 1; color: var(--accent); }

        tbody td { padding: 13px 16px; border-bottom: 1px solid var(--border); vertical-align: middle; }
        tbody tr:last-child td { border-bottom: none; }
        tbody tr { transition: background 0.12s ease; cursor: pointer; }
        tbody tr:hover { background: rgba(255,255,255,0.03); }
        tbody tr.selected { background: rgba(79,255,176,0.04); }
        tbody tr.selected td { border-bottom-color: rgba(79,255,176,0.08); }

        .ticket-id {
            font-family: var(--font-mono);
            color: var(--muted);
            font-size: 12px;
            font-weight: 500;
        }

        .ticket-title-link { color: var(--text); font-weight: 600; font-size: 13.5px; }
        tbody tr:hover .ticket-title-link { color: var(--accent); }
        tbody tr.selected .ticket-title-link { color: var(--accent); }

        .row-actions {
            display: flex;
            align-items: center;
            gap: 4px;
            opacity: 0;
            transition: opacity 0.15s;
        }
        tbody tr:hover .row-actions { opacity: 1; }

        .empty-state {
            padding: 48px 24px;
            text-align: center;
            color: var(--muted);
            display: none;
        }
        .empty-state strong { color: var(--text); display: block; margin-bottom: 6px; font-size: 1rem; }
        .empty-state svg { margin-bottom: 12px; opacity: 0.3; }

        /* ===== MOBILE TICKET CARDS ===== */
        .m-card-list { display: none; flex-direction: column; gap: 8px; }

        .m-ticket-card {
            background: var(--glass);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 14px 16px;
            cursor: pointer;
            transition: all 0.15s ease;
            backdrop-filter: blur(16px);
        }
        .m-ticket-card:active { transform: scale(0.99); }
        .m-ticket-card:hover { border-color: var(--border-strong); }
        .m-ticket-card.selected { border-color: rgba(79,255,176,0.35); background: rgba(79,255,176,0.04); }

        .m-ticket-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 8px;
        }
        .m-ticket-id {
            font-family: var(--font-mono);
            font-size: 10.5px;
            color: var(--muted);
            margin-bottom: 3px;
        }
        .m-ticket-title {
            font-size: 13.5px;
            font-weight: 600;
            line-height: 1.35;
            color: var(--text);
        }
        .m-ticket-card.selected .m-ticket-title { color: var(--accent); }

        .m-ticket-badges {
            display: flex;
            align-items: center;
            gap: 5px;
            flex-wrap: wrap;
            margin-bottom: 10px;
        }
        .m-ticket-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding-top: 8px;
            border-top: 1px solid var(--border);
        }
        .m-ticket-assignee {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--muted);
        }
        .m-ticket-time {
            font-size: 11px;
            color: var(--muted);
            font-family: var(--font-mono);
        }
        .m-ticket-actions {
            display: flex;
            gap: 2px;
        }

        /* ===== DETAIL PANEL ===== */
        .detail-grid {
            display: grid;
            grid-template-columns: 1.5fr 0.8fr;
            gap: 16px;
            margin-top: 18px;
            align-items: start;
        }

        .detail-card { padding: 22px; }

        .detail-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 10px;
        }

        .detail-card h2 {
            font-size: 1.25rem;
            letter-spacing: -0.04em;
            line-height: 1.25;
            font-family: var(--font-display);
            font-weight: 800;
        }
        .detail-card p { color: var(--muted); font-size: 13.5px; line-height: 1.65; }

        .detail-meta {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin-top: 16px;
        }

        .detail-meta-item {
            padding: 13px;
            border: 1px solid var(--border);
            background: rgba(255,255,255,0.03);
            border-radius: 12px;
            transition: border-color 0.15s;
        }
        .detail-meta-item:hover { border-color: var(--border-strong); }
        .detail-meta-item strong {
            display: block;
            color: var(--muted);
            font-size: 10.5px;
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            font-family: var(--font-mono);
            font-weight: 600;
        }

        .detail-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-top: 18px;
            padding-top: 16px;
            border-top: 1px solid var(--border);
        }

        /* ===== ACTIVITY ===== */
        .activity-panel h3 {
            font-size: 13.5px;
            font-weight: 700;
            margin-bottom: 4px;
            font-family: var(--font-display);
        }
        .activity-panel p { font-size: 12px; color: var(--muted); }

        .activity-list { margin-top: 14px; }

        .activity-item {
            display: flex;
            gap: 10px;
            padding: 11px 0;
            border-bottom: 1px solid var(--border);
            animation: fadeInUp 0.2s ease both;
        }
        .activity-item:last-child { border-bottom: none; }

        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .activity-dot {
            width: 7px; height: 7px;
            border-radius: 50%;
            background: var(--accent);
            margin-top: 5px;
            flex-shrink: 0;
            box-shadow: 0 0 10px rgba(79,255,176,0.5);
        }

        .activity-item h4 { font-size: 12.5px; font-weight: 600; margin-bottom: 2px; }
        .activity-item span { color: var(--muted); font-size: 11px; font-family: var(--font-mono); }

        .comment-box {
            margin-top: 14px;
            padding-top: 14px;
            border-top: 1px solid var(--border);
        }
        .comment-input-row {
            display: flex;
            gap: 8px;
            align-items: flex-start;
        }
        .comment-textarea {
            flex: 1;
            border: 1px solid var(--border);
            background: rgba(255,255,255,0.04);
            color: var(--text);
            border-radius: var(--radius-sm);
            padding: 9px 12px;
            outline: none;
            font-family: var(--font-body);
            font-size: 13px;
            resize: none;
            min-height: 38px;
            transition: all 0.15s;
        }
        .comment-textarea:focus {
            border-color: rgba(79,255,176,0.4);
            min-height: 70px;
        }
        .comment-textarea::placeholder { color: var(--muted); }

        /* ===== MODALS ===== */
        .modal-backdrop {
            position: fixed;
            inset: 0;
            z-index: 300;
            background: rgba(0,0,0,0.7);
            backdrop-filter: blur(12px);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .modal-backdrop.show { display: flex; animation: backdropIn 0.18s ease; }
        @@keyframes backdropIn { from { opacity: 0; } to { opacity: 1; } }

        .modal-card {
            width: min(100%, 620px);
            background: rgba(13,21,37,0.98);
            border: 1px solid var(--border-strong);
            border-radius: 20px;
            box-shadow: 0 48px 120px rgba(0,0,0,0.6);
            overflow: hidden;
            animation: modalIn 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        @@keyframes modalIn {
            from { opacity: 0; transform: scale(0.94) translateY(12px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }

        .modal-card.modal-sm { width: min(100%, 420px); }
        .modal-card.modal-lg { width: min(100%, 680px); }

        .modal-header {
            padding: 18px 22px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }
        .modal-header h2 {
            font-size: 1.1rem;
            letter-spacing: -0.04em;
            font-family: var(--font-display);
            font-weight: 800;
        }
        .modal-header-meta { display: flex; align-items: center; gap: 8px; }

        .modal-body { padding: 20px 22px; display: grid; gap: 14px; }

        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
        .form-group { display: grid; gap: 5px; }

        .form-label {
            color: var(--muted);
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            font-family: var(--font-mono);
        }

        .form-control {
            width: 100%;
            border: 1px solid var(--border);
            background: rgba(255,255,255,0.04);
            color: var(--text);
            border-radius: var(--radius-sm);
            padding: 10px 12px;
            outline: none;
            font-family: var(--font-body);
            font-size: 13.5px;
            transition: all 0.15s ease;
        }
        .form-control:focus {
            border-color: rgba(79,255,176,0.4);
            box-shadow: 0 0 0 3px rgba(79,255,176,0.06);
            background: rgba(255,255,255,0.06);
        }
        .form-control option { background: #0d1525; }
        textarea.form-control { resize: vertical; min-height: 100px; }

        .modal-actions {
            padding: 16px 22px;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            flex-wrap: wrap;
        }

        .delete-icon {
            width: 52px; height: 52px;
            border-radius: 50%;
            background: rgba(255,79,106,0.12);
            border: 1px solid rgba(255,79,106,0.25);
            display: grid;
            place-items: center;
            margin: 0 auto 14px;
        }
        .delete-modal-body { padding: 24px 22px; text-align: center; }
        .delete-modal-body h3 { font-family: var(--font-display); font-size: 1.1rem; margin-bottom: 8px; }
        .delete-modal-body p { color: var(--muted); font-size: 13px; }

        .status-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
        .status-option {
            padding: 14px;
            border: 1px solid var(--border);
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.15s;
            background: rgba(255,255,255,0.03);
            -webkit-tap-highlight-color: transparent;
        }
        .status-option:hover { border-color: var(--border-strong); background: rgba(255,255,255,0.06); }
        .status-option.selected { border-color: rgba(79,255,176,0.4); background: rgba(79,255,176,0.06); }
        .status-option .status-name { font-weight: 600; font-size: 13px; margin-top: 6px; }
        .status-option .status-desc { font-size: 11.5px; color: var(--muted); margin-top: 2px; }

        .kbd {
            display: inline-flex;
            align-items: center;
            padding: 1px 5px;
            border: 1px solid var(--border-strong);
            border-radius: 4px;
            font-size: 10px;
            font-family: var(--font-mono);
            color: var(--muted);
            background: rgba(255,255,255,0.04);
        }

        /* ===== TOAST ===== */
        .toast-container {
            position: fixed;
            right: 20px; bottom: 20px;
            z-index: 500;
            display: flex;
            flex-direction: column;
            gap: 8px;
            pointer-events: none;
        }

        .toast {
            background: rgba(15,27,48,0.95);
            border: 1px solid var(--border-strong);
            color: var(--text);
            padding: 12px 16px;
            border-radius: 12px;
            box-shadow: var(--shadow);
            backdrop-filter: blur(20px);
            font-size: 13.5px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 10px;
            pointer-events: all;
            transform: translateX(120%);
            transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
            max-width: 320px;
        }
        .toast.show { transform: translateX(0); }
        .toast.leaving { transform: translateX(120%); transition: transform 0.2s ease; }
        .toast-icon { width: 18px; height: 18px; border-radius: 50%; display: grid; place-items: center; flex-shrink: 0; }
        .toast-success .toast-icon { background: rgba(79,255,176,0.15); color: var(--accent); }
        .toast-error .toast-icon { background: rgba(255,79,106,0.15); color: var(--danger); }
        .toast-info .toast-icon { background: rgba(77,158,255,0.15); color: var(--info); }

        /* ===== MOBILE BACKDROP ===== */
        .mobile-backdrop {
            position: fixed;
            inset: 0;
            z-index: 190;
            /* No backdrop-filter here — it would visually blur the sidebar even at higher z-index
               because backdrop-filter composites against the paint layer, not z-order */
            background: rgba(0,0,0,0.65);
            display: none;
        }
        .mobile-backdrop.show { display: block; }

        /* When sidebar is open, shift the backdrop to start after the sidebar so it
           never sits behind/over the sidebar's rendered pixels */
        .sidebar.open ~ .mobile-backdrop,
        body.sidebar-open .mobile-backdrop {
            /* Can't easily use a sibling selector here since backdrop is before sidebar in DOM,
               so we handle this via JS class on body instead */
        }

        /* ===== MOBILE BOTTOM NAV ===== */
        .mobile-bottom-nav {
            display: none;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            z-index: 150;
            background: rgba(8,13,26,0.97);
            border-top: 1px solid var(--border-strong);
            backdrop-filter: blur(24px);
            padding: 6px 0 max(6px, env(safe-area-inset-bottom));
        }
        .mobile-bottom-nav-inner {
            display: flex;
            align-items: stretch;
        }
        .bottom-nav-item {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 3px;
            padding: 6px 4px;
            color: var(--muted);
            font-size: 9.5px;
            font-weight: 700;
            font-family: var(--font-mono);
            cursor: pointer;
            background: transparent;
            border: none;
            transition: color 0.15s;
            -webkit-tap-highlight-color: transparent;
            min-height: 48px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .bottom-nav-item:hover, .bottom-nav-item.active { color: var(--accent); }
        .bottom-nav-item.new-btn {
            color: #030810;
        }
        .bottom-nav-item.new-btn .btn-new-inner {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 3px;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            border-radius: 12px;
            padding: 7px 16px;
            width: 100%;
            color: #030810;
        }
        .bottom-nav-item svg { flex-shrink: 0; }

        /* ===== USER LINK CARD ===== */
        .user-link-card {
            cursor: pointer;
            transition: all 0.15s ease;
        }
        .user-link-card:hover {
            background: rgba(255,255,255,0.07);
            border-color: var(--border-strong);
        }
        .user-link-card:focus-visible {
            outline: 2px solid rgba(79,255,176,0.5);
            outline-offset: 2px;
        }

        /* ===== RESPONSIVE ===== */

        /* Tablet */
        @@media (max-width: 1100px) {
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
            .detail-grid { grid-template-columns: 1fr; }
            .search-bar { width: 240px; }
        }

        /* Mobile */
        @@media (max-width: 860px) {
            :root { --header-h: 56px; }

            /* Sidebar overlay */
            .sidebar {
                transform: translateX(-100%);
                transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
                box-shadow: var(--shadow);
                width: min(var(--sidebar-w), 82vw);
            }
            .sidebar.open { transform: translateX(0); }

            /* Critical: on mobile the sidebar is out of flow (fixed),
               so main-content must be exactly the viewport width */
            .main-content {
                margin-left: 0;
                width: 100vw;
                max-width: 100vw;
                overflow-x: hidden;
            }

            .mobile-menu { display: inline-flex; }

            /* Header — must not exceed viewport */
            .page-header {
                padding: 0 14px;
                gap: 8px;
                width: 100%;
                max-width: 100vw;
                box-sizing: border-box;
            }
            .page-header h1 { font-size: 1.05rem; }
            .page-header-left { min-width: 0; flex-shrink: 1; overflow: hidden; }
            .page-actions { flex-shrink: 0; }
            .breadcrumb { display: none; }

            /* Page body */
            .page-body {
                padding: 16px 14px 84px;
                width: 100%;
                max-width: 100vw;
                box-sizing: border-box;
                overflow-x: hidden;
            }

            /* Stats 2-col */
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 10px;
                margin-bottom: 16px;
                width: 100%;
            }
            .stat-card { padding: 14px 16px; }
            .stat-value { font-size: 2rem; }

            /* Filter bar — contained horizontal scroll, must NOT cause page overflow.
               The key is width:100% + overflow-x:auto on the container itself. */
            .filter-bar {
                flex-wrap: nowrap;
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
                gap: 6px;
                margin-bottom: 10px;
                padding-bottom: 4px;
                scrollbar-width: none;
                -ms-overflow-style: none;
                width: 100%;
                max-width: 100%;
                box-sizing: border-box;
            }
            .filter-bar::-webkit-scrollbar { display: none; }
            .result-count { display: none; }
            .filter-select { flex-shrink: 0; font-size: 12px; padding: 7px 10px; min-height: 36px; }
            #clearFilters { flex-shrink: 0; }

            /* Table hidden, card list shown */
            .table-wrap { display: none; }
            .m-card-list { display: flex; width: 100%; }

            /* Detail panel stacked */
            .detail-grid {
                grid-template-columns: 1fr;
                gap: 12px;
                margin-top: 12px;
            }
            .detail-card { padding: 16px; }
            .detail-meta { grid-template-columns: repeat(2, 1fr); gap: 8px; }
            .detail-meta-item { padding: 10px; }
            .detail-actions { gap: 6px; }
            .detail-actions .btn { flex: 1; justify-content: center; font-size: 12px; padding: 8px 10px; }

            /* Modals slide up from bottom */
            .modal-backdrop {
                align-items: flex-end;
                padding: 0;
            }
            .modal-card {
                width: 100%;
                border-radius: 20px 20px 0 0;
                max-height: 90vh;
                overflow-y: auto;
                animation: slideUp 0.28s cubic-bezier(0.34, 1.2, 0.64, 1);
            }
            .modal-card.modal-sm { width: 100%; }
            .modal-card.modal-lg { width: 100%; }
            @@keyframes slideUp {
                from { opacity: 0.5; transform: translateY(60px); }
                to { opacity: 1; transform: translateY(0); }
            }

            /* Modal drag handle */
            .modal-card::before {
                content: '';
                display: block;
                width: 36px;
                height: 4px;
                border-radius: 999px;
                background: rgba(255,255,255,0.15);
                margin: 10px auto 0;
            }

            .modal-header { padding: 12px 18px; }
            .modal-body { padding: 14px 18px; gap: 12px; }
            .modal-actions { padding: 12px 18px; flex-wrap: nowrap; }
            .form-row { grid-template-columns: 1fr; gap: 10px; }
            .delete-modal-body { padding: 20px 18px 14px; }
            .status-grid { grid-template-columns: 1fr 1fr; gap: 8px; }
            .status-option { padding: 11px; }

            /* Search in header → hidden, show toggle icon */
            .page-actions .search-bar { display: none; }
            #mobileSearchToggle { display: inline-flex !important; }

            /* Bottom nav visible */
            .mobile-bottom-nav { display: block; }

            /* Touch targets */
            .btn { min-height: 40px; }
            .btn-sm { min-height: 36px; }
            .btn-icon { min-height: 40px; min-width: 40px; }
            .nav-item { min-height: 44px; padding: 10px 14px; }

            /* Toast position */
            .toast-container { right: 14px; bottom: 80px; }
            .toast { max-width: calc(100vw - 28px); }
        }

        /* Small phones */
        @@media (max-width: 480px) {
            :root { --header-h: 52px; }

            .page-header { padding: 0 12px; }
            .page-header h1 { font-size: 0.95rem; }

            .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }
            .stat-card { padding: 12px 14px; }
            .stat-value { font-size: 1.75rem; }
            .stat-sub { display: none; }

            .page-body { padding: 12px 12px 80px; }

            /* Detail actions: 2-col grid */
            .detail-actions {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 6px;
            }
            .detail-actions .btn { width: 100%; }

            /* Export button: icon only */
            #exportBtn .export-label { display: none; }

            .modal-actions { gap: 8px; }
            .modal-actions .btn { flex: 1; justify-content: center; }
        }
    </style>
</head>
<body>

<div class="mobile-backdrop" id="mobileBackdrop"></div>

<!-- Floating mobile search bar -->
<div class="mobile-search-bar" id="mobileSearchBar">
    <svg width="14" height="14" fill="none" stroke="var(--muted)" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
    <input id="mobileSearchInput" type="search" placeholder="Search tickets…" autocomplete="off" />
    <button class="btn btn-ghost btn-icon btn-sm" id="closeMobileSearch" type="button">
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
</div>

<div class="app-layout">
    <!-- ===== SIDEBAR ===== -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <div class="logo-mark">BT</div>
            <div class="logo-text">Bug<span>Track</span></div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">Main</div>

            <a class="nav-item" asp-action="Index" asp-controller="Home">
                <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 11l9-8 9 8"/><path d="M5 10v10h14V10"/></svg>
                Home
            </a>

            <button class="nav-item active" type="button" id="allTicketsBtn">
                <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                All Tickets
                <span class="nav-badge" id="navTicketCount">0</span>
            </button>
            <button class="nav-item" type="button" id="myIssuesBtn">
                <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4" /><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" /></svg>
                My Issues
            </button>
            <div class="nav-section-label">Management</div>

                <button class="nav-item" data-ph="bt_new_ticket_click" type="button" id="openCreateModalSide">
                <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
