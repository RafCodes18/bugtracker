// ========== CREATE TICKET ==========
function openCreateModal() {
    document.getElementById("createTitle").value = "";
    document.getElementById("createDescription").value = "";
    document.getElementById("createType").value = "Bug";
    document.getElementById("createStatus").value = "Open";
    document.getElementById("createPriority").value = "Medium";
    document.getElementById("createAssignee").value = "Rafael Parra";
    openModal("createModal");
    setTimeout(() => document.getElementById("createTitle").focus(), 80);
}

document.getElementById("openCreateModal").addEventListener("click", openCreateModal);
document.getElementById("openCreateModalSide").addEventListener("click", openCreateModal);

        document.getElementById("submitCreate").addEventListener("click", async () => {
            const title = document.getElementById("createTitle").value.trim();
            const desc = document.getElementById("createDescription").value.trim();
            if (!title || !desc) { toast("Please fill in all required fields.", "error"); return; }
            try {
                const saved = await postJson(urls.create, {
                    title, description: desc,
                    type: document.getElementById("createType").value,
                    status: document.getElementById("createStatus").value,
                    priority: document.getElementById("createPriority").value,
                    assignee: document.getElementById("createAssignee").value
                });
                tickets.unshift(saved);
                selectedTicketId = saved.id;
                closeModal("createModal");
                renderTickets();
                toast("Ticket created and saved to database.", "success");
            } catch (err) { toast(err.message || "Could not create ticket.", "error"); }
        });

// ========== EDIT TICKET ==========
function openEditModal(id) {
    const t = tickets.find(x => x.id === id);
    if (!t) return;
    editingTicketId = id;
    document.getElementById("editModalId").textContent = t.id;
    document.getElementById("editTitle").value = t.title;
    document.getElementById("editDescription").value = t.description;
    document.getElementById("editType").value = t.type;
    document.getElementById("editStatus").value = t.status;
    document.getElementById("editPriority").value = t.priority;
    document.getElementById("editAssignee").value = t.assignee;
    openModal("editModal");
    setTimeout(() => document.getElementById("editTitle").focus(), 80);
}

        document.getElementById("submitEdit").addEventListener("click", async () => {
            const ticket = tickets.find(t => t.id === editingTicketId);
            if (!ticket) { toast("Ticket not found.", "error"); return; }
            const title = document.getElementById("editTitle").value.trim();
            const desc = document.getElementById("editDescription").value.trim();
            if (!title || !desc) { toast("Please fill in all required fields.", "error"); return; }
            try {
                const saved = await postJson(urls.edit, {
                    id: ticket.dbId, title, description: desc,
                    type: document.getElementById("editType").value,
                    status: document.getElementById("editStatus").value,
                    priority: document.getElementById("editPriority").value,
                    assignee: document.getElementById("editAssignee").value
                });
                const index = tickets.findIndex(t => t.dbId === saved.dbId);
                if (index >= 0) tickets[index] = saved;
                selectedTicketId = saved.id;
                editingTicketId = null;
                closeModal("editModal");
                renderTickets();
                toast("Ticket changes saved to database.", "success");
            } catch (err) { toast(err.message || "Could not save changes.", "error"); }
        });

document.getElementById("editDeleteBtn").addEventListener("click", () => {
    closeModal("editModal");
    openDeleteModal(editingTicketId);
});

// ========== DELETE TICKET ==========
function openDeleteModal(id) {
    const t = tickets.find(x => x.id === id);
    if (!t) return;
    deletingTicketId = id;
    document.getElementById("deleteTicketTitle").textContent = t.title;
    openModal("deleteModal");
}

        document.getElementById("confirmDelete").addEventListener("click", async () => {
            const ticket = tickets.find(t => t.id === deletingTicketId);
            if (!ticket) { closeModal("deleteModal"); return; }
            try {
                await postJson(urls.delete, { id: ticket.dbId });
                tickets = tickets.filter(t => t.id !== deletingTicketId);
                selectedTicketId = tickets.length ? tickets[0].id : null;
                deletingTicketId = null;
                closeModal("deleteModal");
                renderTickets();
                toast("Ticket deleted from database.", "success");
            } catch (err) { toast(err.message || "Could not delete ticket.", "error"); }
        });

// ========== STATUS MODAL ==========
function openStatusModal(id) {
    const t = tickets.find(x => x.id === id);
    if (!t) return;
    statusModalTicketId = id;
    selectedStatus = t.status;
    document.getElementById("statusModalTicketTitle").textContent = t.title;
    document.querySelectorAll(".status-option").forEach(opt => {
        opt.classList.toggle("selected", opt.dataset.value === t.status);
    });
    openModal("statusModal");
}

document.querySelectorAll(".status-option").forEach(opt => {
    opt.addEventListener("click", () => {
        selectedStatus = opt.dataset.value;
        document.querySelectorAll(".status-option").forEach(o => o.classList.remove("selected"));
        opt.classList.add("selected");
    });
});

        document.getElementById("confirmStatusChange").addEventListener("click", async () => {
            const ticket = tickets.find(t => t.id === statusModalTicketId);
            if (!ticket || !selectedStatus) { closeModal("statusModal"); return; }
            try {
                const saved = await postJson(urls.changeStatus, { id: ticket.dbId, status: selectedStatus });
                const index = tickets.findIndex(t => t.dbId === saved.dbId);
                if (index >= 0) tickets[index] = saved;
                selectedTicketId = saved.id;
                statusModalTicketId = null;
                selectedStatus = null;
                closeModal("statusModal");
                renderTickets();
                toast("Status saved to database.", "success");
            } catch (err) { toast(err.message || "Could not update status.", "error"); }
        });

// ========== COMMENT (inline) ==========
        document.getElementById("submitComment").addEventListener("click", async () => {
            const input = document.getElementById("commentInput");
            const comment = input.value.trim();
            if (!comment) { toast("Comment cannot be empty.", "error"); return; }
            const ticket = tickets.find(t => t.id === selectedTicketId);
            if (!ticket) { toast("Select a ticket first.", "error"); return; }
            try {
                const saved = await postJson(urls.addComment, { id: ticket.dbId, comment });
                const index = tickets.findIndex(t => t.dbId === saved.dbId);
                if (index >= 0) tickets[index] = saved;
                selectedTicketId = saved.id;
                input.value = "";
                renderTickets();
                toast("Comment saved to database.", "success");
            } catch (err) { toast(err.message || "Could not save comment.", "error"); }
        });

document.getElementById("commentInput").addEventListener("keydown", e => {
    if (e.key === "Enter" && (e.ctrlKey || e.metaKey)) document.getElementById("submitComment").click();
});

// ========== COMMENT MODAL ==========
function openCommentModal(id) {
    commentModalTicketId = id;
    document.getElementById("commentModalId").textContent = id;
    document.getElementById("modalCommentText").value = "";
    openModal("commentModal");
    setTimeout(() => document.getElementById("modalCommentText").focus(), 80);
}

        document.getElementById("submitModalComment").addEventListener("click", async () => {
            const text = document.getElementById("modalCommentText").value.trim();
            if (!text) { toast("Please write a comment.", "error"); return; }
            const ticket = tickets.find(t => t.id === commentModalTicketId);
            if (!ticket) { toast("Ticket not found.", "error"); return; }
            try {
                const saved = await postJson(urls.addComment, { id: ticket.dbId, comment: text });
                const index = tickets.findIndex(t => t.dbId === saved.dbId);
                if (index >= 0) tickets[index] = saved;
                selectedTicketId = saved.id;
                commentModalTicketId = null;
                document.getElementById("modalCommentText").value = "";
                closeModal("commentModal");
                renderTickets();
                toast("Comment saved to database.", "success");
            } catch (err) { toast(err.message || "Could not save comment.", "error"); }
        });

// ========== EXPORT ==========
document.getElementById("exportBtn").addEventListener("click", () => {
    const filtered = getFiltered();
    document.getElementById("exportCount").textContent = filtered.length;
    openModal("exportModal");
});

document.getElementById("confirmExport").addEventListener("click", () => {
    const filtered = getFiltered();
    const fmt = document.getElementById("exportFormat").value;
    const fields = [...document.querySelectorAll("#exportFields input:checked")].map(c => c.value);
    let content = "", mime = "text/plain", ext = fmt;
    if (fmt === "json") {
        content = JSON.stringify(filtered.map(t => { const obj = {}; fields.forEach(f => obj[f] = t[f] || ""); return obj; }), null, 2);
        mime = "application/json";
    } else {
        const sep = fmt === "tsv" ? "\t" : ",";
        const rows = [fields.join(sep), ...filtered.map(t => fields.map(f => `"${(t[f]||"").replace(/"/g,'""')}"`).join(sep))];
        content = rows.join("\n");
        mime = "text/csv";
    }
    const blob = new Blob([content], { type: mime });
    const a = document.createElement("a"); a.href = URL.createObjectURL(blob);
    a.download = `bugtrack-export.${ext}`; a.click();
    closeModal("exportModal");
    toast(`Exported ${filtered.length} tickets as ${fmt.toUpperCase()}.`, "success");
});

// ========== FILTERS ==========
["topSearch","statusFilter","priorityFilter","typeFilter","assigneeFilter"].forEach(id => {
    const el = document.getElementById(id);
    el.addEventListener("input", renderTickets);
    el.addEventListener("change", renderTickets);
});

document.getElementById("clearFilters").addEventListener("click", () => {
    document.getElementById("topSearch").value = "";
    document.getElementById("mobileSearchInput").value = "";
    document.getElementById("statusFilter").value = "";
    document.getElementById("priorityFilter").value = "";
    document.getElementById("typeFilter").value = "";
    document.getElementById("assigneeFilter").value = "";
    renderTickets();
});

// ========== ADMIN LINK ==========
        const adminHomeLink = document.getElementById("adminHomeLink");
        if (adminHomeLink) {
            adminHomeLink.addEventListener("click", () => { window.location.href = adminHomeLink.dataset.url; });
            adminHomeLink.addEventListener("keydown", (e) => {
                if (e.key === "Enter" || e.key === " ") { e.preventDefault(); adminHomeLink.click(); }
            });
        }

        const logoutUrl = '@Url.Action("Logout", "Auth")';
        const homeUrl = '@Url.Action("Index", "Home")';

        document.getElementById("logoutBtn")?.addEventListener("click", async (e) => {
            e.stopPropagation();
            const ok = confirm("Sign out of the BugTrack demo?");
            if (!ok) return;
            try {
                const response = await fetch(logoutUrl, { method: "POST" });
                const result = await response.json();
                window.location.href = result.redirectUrl || homeUrl;
            } catch { window.location.href = homeUrl; }
        });

// ========== MOBILE SIDEBAR ==========
const sidebar = document.getElementById("sidebar");
const mobileBackdrop = document.getElementById("mobileBackdrop");

function closeMobileSidebar() {
    sidebar.classList.remove("open");
    mobileBackdrop.classList.remove("show");
    mobileBackdrop.style.left = "0";
    document.body.style.overflow = "";
}
function openMobileSidebar() {
    sidebar.classList.add("open");
    mobileBackdrop.classList.add("show");
    // Shift backdrop's left edge past the sidebar so its pixels never overlap
    // the sidebar. backdrop-filter bleeds visually across z-index boundaries,
    // so spatial separation is the only reliable fix.
    const sidebarW = sidebar.getBoundingClientRect().width;
    mobileBackdrop.style.left = sidebarW + "px";
    document.body.style.overflow = "hidden";
}

document.getElementById("mobileMenu").addEventListener("click", () => {
    sidebar.classList.contains("open") ? closeMobileSidebar() : openMobileSidebar();
});
mobileBackdrop.addEventListener("click", closeMobileSidebar);
sidebar.querySelectorAll("a.nav-item").forEach(a => a.addEventListener("click", closeMobileSidebar));

// ========== BOTTOM NAV ==========
document.getElementById("bnAllTickets").addEventListener("click", () => {
    document.getElementById("allTicketsBtn").click();
    document.querySelectorAll(".bottom-nav-item").forEach(b => b.classList.remove("active"));
    document.getElementById("bnAllTickets").classList.add("active");
});
document.getElementById("bnMyIssues").addEventListener("click", () => {
    document.getElementById("myIssuesBtn").click();
    document.querySelectorAll(".bottom-nav-item").forEach(b => b.classList.remove("active"));
    document.getElementById("bnMyIssues").classList.add("active");
});
document.getElementById("bnNewTicket").addEventListener("click", () => {
    openCreateModal();
});
document.getElementById("bnSearch").addEventListener("click", () => {
    openMobileSearch();
});
document.getElementById("bnMenu").addEventListener("click", () => {
    sidebar.classList.contains("open") ? closeMobileSidebar() : openMobileSidebar();
});

// ========== INIT ==========
renderTickets();
</script>
