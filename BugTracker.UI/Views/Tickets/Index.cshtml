    <!-- ===== MAIN ===== -->
    <main class="main-content">
        <div class="page-header">
            <div class="page-header-left">
                <button class="btn btn-secondary btn-icon mobile-menu" id="mobileMenu" type="button">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                </button>
                <div>
                    <h1>All Tickets</h1>
                    <div class="breadcrumb">Projects / <span>BugTrack</span></div>
                </div>
            </div>

            <div class="page-actions">
                <!-- Desktop search -->
                <div class="search-bar">
                    <svg width="13" height="13" fill="none" stroke="var(--muted)" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
                    <input id="topSearch" type="text" placeholder="Search tickets…" />
                </div>

                <!-- Mobile search toggle -->
                <button class="btn btn-secondary btn-icon btn-sm" id="mobileSearchToggle" type="button" title="Search" style="display:none;">
                    <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
                </button>

                    <button class="btn btn-secondary btn-sm" data-ph="bt_export_click" id="exportBtn" type="button">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    <span class="export-label">Export</span>
                </button>

                    <button class="btn btn-primary btn-sm" data-ph="bt_new_ticket_click" id="openCreateModal" type="button">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    New Ticket
                </button>
            </div>
        </div>

        <div class="page-body">
            <!-- Stats -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-label">Open</div>
                    <div class="stat-value" style="color:var(--info);" id="openCount">0</div>
                    <div class="stat-sub"><span class="stat-up">▲ 3</span> from last week</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">In Progress</div>
                    <div class="stat-value" style="color:var(--warning);" id="progressCount">0</div>
                    <div class="stat-sub"><span class="stat-down">▼ 2</span> from last week</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">High Priority</div>
                    <div class="stat-value" style="color:var(--danger);" id="highCount">0</div>
                    <div class="stat-sub">Needs attention</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Resolved</div>
                    <div class="stat-value" style="color:var(--success);" id="resolvedCount">0</div>
                    <div class="stat-sub"><span class="stat-up">▲ 12</span> this month</div>
                </div>
            </div>

            <!-- Filter bar -->
            <div class="filter-bar">
                <select class="filter-select" id="statusFilter">
                    <option value="">All Statuses</option>
                    <option value="Open">Open</option>
                    <option value="In Progress">In Progress</option>
                    <option value="Review">Review</option>
                    <option value="Resolved">Resolved</option>
                </select>
                <select class="filter-select" id="priorityFilter">
                    <option value="">All Priorities</option>
                    <option value="Critical">Critical</option>
                    <option value="High">High</option>
                    <option value="Medium">Medium</option>
                    <option value="Low">Low</option>
                </select>
                <select class="filter-select" id="typeFilter">
                    <option value="">All Types</option>
                    <option value="Bug">Bug</option>
                    <option value="Feature">Feature</option>
                    <option value="Task">Task</option>
                </select>
                <select class="filter-select" id="assigneeFilter">
                    <option value="">All Assignees</option>
                    <option value="Rafael Parra">Rafael Parra</option>
                    <option value="M. Chen">M. Chen</option>
                    <option value="S. Patel">S. Patel</option>
                    <option value="T. Kowalski">T. Kowalski</option>
                </select>
                <button class="btn btn-ghost btn-sm" id="clearFilters" type="button">
                    <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Clear
                </button>
                <span class="result-count" id="resultCount"></span>
            </div>

            <!-- Desktop Table -->
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th style="width:70px;" data-sort="id">ID</th>
                            <th data-sort="title">Title</th>
                            <th style="width:95px;" data-sort="type">Type</th>
                            <th style="width:120px;" data-sort="status">Status</th>
                            <th style="width:110px;" data-sort="priority">Priority</th>
                            <th style="width:150px;">Assignee</th>
                            <th style="width:100px;" data-sort="updated">Updated</th>
                            <th style="width:80px;"></th>
                        </tr>
                    </thead>
                    <tbody id="ticketTableBody"></tbody>
                </table>
                <div class="empty-state" id="emptyState">
                    <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    <strong>No tickets found</strong>
                    Try adjusting your filters or create a new ticket.
                </div>
            </div>

            <!-- Mobile Card List -->
            <div class="m-card-list" id="mCardList"></div>
            <div class="empty-state" id="emptyStateMobile" style="display:none;">
                <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                <strong>No tickets found</strong>
                Try adjusting your filters or create a new ticket.
            </div>

            <!-- Detail + Activity -->
            <div class="detail-grid">
                <section class="card detail-card" id="ticketDetail">
                    <div style="color:var(--muted);font-size:13px;text-align:center;padding:20px 0;">
                        Select a ticket to view details
                    </div>
                </section>
                <aside class="card detail-card activity-panel">
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:4px;">
                        <h3>Activity</h3>
                        <span style="font-size:11px;color:var(--muted);font-family:var(--font-mono);" id="activityTicketId">—</span>
                    </div>
                    <p id="activitySubtitle">Select a ticket to view updates.</p>
                    <div class="activity-list" id="activityList"></div>
                    <div class="comment-box" id="commentBox" style="display:none;">
                        <div class="comment-input-row">
                            <textarea class="comment-textarea" id="commentInput" placeholder="Add a comment…" rows="1"></textarea>
                                <button class="btn btn-primary btn-sm btn-icon" id="submitComment" data-ph="bt_submit_comment" title="Post">
                                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                            </button>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </main>
</div>

