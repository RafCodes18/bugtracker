    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #080d1a;
            --card: rgba(13, 21, 37, 0.96);
            --text: #eef2ff;
            --muted: #8896b3;
            --faint: rgba(255,255,255,0.04);
            --accent: #4fffb0;
            --accent-2: #4d9eff;
            --accent-3: #b06eff;
            --border: rgba(255,255,255,0.08);
            --border-strong: rgba(255,255,255,0.14);
            --shadow: 0 48px 120px rgba(0,0,0,0.6);
            --danger: #ff4f6a;
            --font-display: 'Syne', sans-serif;
            --font-body: 'DM Sans', sans-serif;
            --font-mono: 'DM Mono', monospace;
        }

        html, body {
            min-height: 100vh;
            font-family: var(--font-body);
            font-size: 14px;
            color: var(--text);
            background: var(--bg);
            overflow-x: hidden;
        }

        /* ── ANIMATED BACKGROUND ── */
        .bg-layer {
            position: fixed;
            inset: 0;
            z-index: 0;
            overflow: hidden;
        }

        /* Radial gradient mesh */
        .bg-layer::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                radial-gradient(ellipse 70% 60% at 15% 10%, rgba(77,158,255,0.14) 0%, transparent 55%),
                radial-gradient(ellipse 50% 40% at 85% 5%,  rgba(79,255,176,0.09) 0%, transparent 50%),
                radial-gradient(ellipse 60% 50% at 50% 95%, rgba(176,110,255,0.08) 0%, transparent 50%);
        }

        /* Floating orbs */
        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.25;
            animation: drift linear infinite;
        }
        .orb-1 { width: 420px; height: 420px; background: var(--accent-2); top: -10%; left: -8%; animation-duration: 28s; }
        .orb-2 { width: 320px; height: 320px; background: var(--accent);   bottom: -8%; right: -5%; animation-duration: 22s; animation-delay: -8s; }
        .orb-3 { width: 260px; height: 260px; background: var(--accent-3); top: 40%; left: 60%; animation-duration: 34s; animation-delay: -14s; }

        @@keyframes drift {
            0%   { transform: translate(0, 0) scale(1); }
            33%  { transform: translate(30px, -20px) scale(1.05); }
            66%  { transform: translate(-20px, 30px) scale(0.97); }
            100% { transform: translate(0, 0) scale(1); }
        }

        /* Grid lines overlay */
        .grid-overlay {
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
            background-size: 48px 48px;
            mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
        }

        /* ── LAYOUT ── */
        .page {
            position: relative;
            z-index: 1;
            display: grid;
            grid-template-columns: 1fr 1fr;
            min-height: 100vh;
        }

        /* ── LEFT PANEL ── */
        .left-panel {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 48px 56px;
            position: relative;
            overflow: hidden;
        }

        .left-panel::after {
            content: '';
            position: absolute;
            top: 0; right: 0;
            width: 1px;
            height: 100%;
            background: linear-gradient(to bottom, transparent, var(--border-strong) 30%, var(--border-strong) 70%, transparent);
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 11px;
            animation: slideDown 0.6s cubic-bezier(0.34,1.56,0.64,1) both;
        }

        .logo-mark {
            width: 38px; height: 38px;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            color: #030810;
            border-radius: 12px;
            display: grid;
            place-items: center;
            font-family: var(--font-display);
            font-weight: 900;
            font-size: 13px;
            letter-spacing: -0.03em;
            flex-shrink: 0;
            box-shadow: 0 0 32px rgba(79,255,176,0.25);
        }

        .logo-text {
            font-family: var(--font-display);
            font-weight: 900;
            font-size: 1.3rem;
            letter-spacing: -0.05em;
        }
        .logo-text span { color: var(--accent); }

        /* Hero copy */
        .hero {
            animation: slideUp 0.7s cubic-bezier(0.34,1.56,0.64,1) 0.1s both;
        }

        .hero-eyebrow {
            font-family: var(--font-mono);
            font-size: 11px;
            font-weight: 500;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 0.15em;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .hero-eyebrow::before {
            content: '';
            width: 24px; height: 1px;
            background: var(--accent);
            opacity: 0.6;
        }

        .hero h1 {
            font-family: var(--font-display);
            font-size: clamp(2.2rem, 4vw, 3.4rem);
            font-weight: 900;
            letter-spacing: -0.06em;
            line-height: 1.0;
            margin-bottom: 20px;
        }

        .hero h1 .highlight {
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero p {
            color: var(--muted);
            font-size: 15px;
            line-height: 1.7;
            max-width: 380px;
        }

        /* Stats strip */
        .stats-strip {
            display: flex;
            gap: 28px;
            margin-top: 36px;
            animation: slideUp 0.7s cubic-bezier(0.34,1.56,0.64,1) 0.2s both;
        }

        .stat-item {}
        .stat-item .val {
            font-family: var(--font-display);
            font-size: 1.8rem;
            font-weight: 900;
            letter-spacing: -0.06em;
            line-height: 1;
            background: linear-gradient(135deg, var(--text), var(--muted));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .stat-item .lbl {
            font-size: 11.5px;
            color: var(--muted);
            margin-top: 3px;
            font-family: var(--font-mono);
        }

        /* Testimonial / social proof */
        .testimonial {
            padding: 18px 20px;
            border: 1px solid var(--border);
            border-radius: 14px;
            background: rgba(255,255,255,0.03);
            backdrop-filter: blur(10px);
            animation: slideUp 0.7s cubic-bezier(0.34,1.56,0.64,1) 0.25s both;
        }

        .testimonial p {
            font-size: 13.5px;
            color: var(--text);
            line-height: 1.65;
            font-style: italic;
            margin-bottom: 12px;
        }
        .testimonial p::before { content: '\201C'; color: var(--accent); font-size: 1.2em; }
        .testimonial p::after  { content: '\201D'; color: var(--accent); font-size: 1.2em; }

        .testimonial-author {
            display: flex;
            align-items: center;
            gap: 9px;
        }
        .t-avatar {
            width: 28px; height: 28px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(79,255,176,0.2), rgba(77,158,255,0.2));
            border: 1px solid rgba(79,255,176,0.25);
            display: grid;
            place-items: center;
            font-size: 10px;
            font-weight: 700;
            font-family: var(--font-mono);
            color: var(--accent);
        }
        .t-name { font-size: 12.5px; font-weight: 700; }
        .t-role { font-size: 11px; color: var(--muted); font-family: var(--font-mono); }

        /* ── RIGHT PANEL ── */
        .right-panel {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 32px;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            background: var(--card);
            border: 1px solid var(--border-strong);
            border-radius: 22px;
            box-shadow: var(--shadow);
            backdrop-filter: blur(24px);
            overflow: hidden;
            animation: cardIn 0.7s cubic-bezier(0.34,1.56,0.64,1) 0.15s both;
        }

        @@keyframes cardIn {
            from { opacity: 0; transform: translateY(24px) scale(0.97); }
            to   { opacity: 1; transform: translateY(0)   scale(1); }
        }

        .card-header {
            padding: 28px 28px 0;
        }

        .card-header h2 {
            font-family: var(--font-display);
            font-size: 1.55rem;
            font-weight: 900;
            letter-spacing: -0.05em;
            margin-bottom: 5px;
        }

        .card-header p {
            color: var(--muted);
            font-size: 13.5px;
        }

        /* Demo badge */
        .demo-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 6px 12px;
            background: rgba(79,255,176,0.08);
            border: 1px solid rgba(79,255,176,0.22);
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
            color: var(--accent);
            font-family: var(--font-mono);
            margin: 16px 28px 0;
            cursor: pointer;
            transition: all 0.15s;
            width: calc(100% - 56px);
            justify-content: center;
        }
        .demo-badge:hover {
            background: rgba(79,255,176,0.13);
            border-color: rgba(79,255,176,0.4);
            transform: translateY(-1px);
        }
        .demo-badge svg { opacity: 0.8; }

        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 18px 28px 0;
            color: var(--muted);
            font-size: 12px;
            font-family: var(--font-mono);
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        /* Form */
        .card-body {
            padding: 16px 28px 0;
            display: grid;
            gap: 14px;
        }

        .form-group { display: grid; gap: 5px; }

        .form-label {
            font-size: 11.5px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-family: var(--font-mono);
        }

        .input-wrap {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            pointer-events: none;
            transition: color 0.15s;
        }

        .form-control {
            width: 100%;
            border: 1px solid var(--border);
            background: rgba(255,255,255,0.04);
            color: var(--text);
            border-radius: 11px;
            padding: 11px 12px 11px 38px;
            outline: none;
            font-family: var(--font-body);
            font-size: 14px;
            transition: all 0.15s ease;
        }
        .form-control:focus {
            border-color: rgba(79,255,176,0.45);
            box-shadow: 0 0 0 3px rgba(79,255,176,0.07);
            background: rgba(255,255,255,0.06);
        }
        .form-control:focus + .input-icon,
        .input-wrap:focus-within .input-icon { color: var(--accent); }
        .form-control::placeholder { color: var(--muted); opacity: 0.7; }

        /* Password toggle */
        .pwd-toggle {
            position: absolute;
            right: 11px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: var(--muted);
            padding: 4px;
            border-radius: 6px;
            transition: color 0.15s;
            display: grid;
            place-items: center;
        }
        .pwd-toggle:hover { color: var(--text); }

        /* Error state */
        .form-control.error { border-color: rgba(255,79,106,0.5); }
        .error-msg {
            font-size: 12px;
            color: var(--danger);
            font-family: var(--font-mono);
            display: none;
            animation: shake 0.3s ease;
        }
        .error-msg.show { display: block; }
        @@keyframes shake {
            0%,100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }

        /* Remember + forgot row */
        .meta-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .remember {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            user-select: none;
        }

        .remember input[type="checkbox"] { display: none; }

        .check-box {
            width: 16px; height: 16px;
            border: 1.5px solid var(--border-strong);
            border-radius: 5px;
            background: rgba(255,255,255,0.04);
            transition: all 0.15s;
            display: grid;
            place-items: center;
            flex-shrink: 0;
        }
        .check-box svg { opacity: 0; transform: scale(0.5); transition: all 0.15s; }
        .remember input:checked ~ .check-box {
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            border-color: transparent;
        }
        .remember input:checked ~ .check-box svg { opacity: 1; transform: scale(1); }

        .remember-label { font-size: 13px; color: var(--muted); }

        .forgot-link {
            font-size: 12.5px;
            color: var(--accent-2);
            text-decoration: none;
            font-weight: 600;
            opacity: 0.9;
            transition: opacity 0.15s;
        }
        .forgot-link:hover { opacity: 1; }

        /* Submit button */
        .btn-submit {
            width: 100%;
            padding: 13px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-2) 100%);
            color: #030810;
            font-family: var(--font-display);
            font-weight: 800;
            font-size: 15px;
            letter-spacing: -0.03em;
            cursor: pointer;
            transition: all 0.18s ease;
            box-shadow: 0 0 32px rgba(79,255,176,0.18);
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 48px rgba(79,255,176,0.28);
        }
        .btn-submit:active { transform: translateY(0); }
        .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

        /* Shimmer on button */
        .btn-submit::after {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 60%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
            transform: skewX(-15deg);
            transition: none;
        }
        .btn-submit:hover::after {
            animation: shimmer 0.5s ease forwards;
        }
        @@keyframes shimmer {
            to { left: 160%; }
        }

        /* Loading spinner */
        .spinner {
            width: 16px; height: 16px;
            border: 2.5px solid rgba(3,8,16,0.3);
            border-top-color: #030810;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            display: none;
        }
        .btn-submit.loading .spinner { display: block; }
        .btn-submit.loading .btn-text { opacity: 0.7; }
        @@keyframes spin { to { transform: rotate(360deg); } }

        /* Card footer */
        .card-footer {
            padding: 20px 28px 28px;
            text-align: center;
        }

        .card-footer p {
            font-size: 13px;
            color: var(--muted);
        }

        .signup-link {
            color: var(--accent);
            font-weight: 700;
            text-decoration: none;
        }
        .signup-link:hover { text-decoration: underline; }

        /* Terms */
        .terms {
            font-size: 11.5px;
            color: var(--muted);
            text-align: center;
            padding: 0 28px 24px;
            line-height: 1.6;
        }
        .terms a { color: var(--accent-2); text-decoration: none; }
        .terms a:hover { text-decoration: underline; }

        /* Success state */
        .success-overlay {
            position: absolute;
            inset: 0;
            background: var(--card);
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 14px;
            border-radius: 22px;
            animation: fadeIn 0.3s ease;
            z-index: 10;
        }
        .success-overlay.show { display: flex; }
        @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        .success-icon {
            width: 64px; height: 64px;
            border-radius: 50%;
            background: rgba(79,255,176,0.12);
            border: 1px solid rgba(79,255,176,0.3);
            display: grid;
            place-items: center;
            animation: popIn 0.4s cubic-bezier(0.34,1.56,0.64,1);
        }
        @@keyframes popIn {
            from { transform: scale(0.5); opacity: 0; }
            to   { transform: scale(1);   opacity: 1; }
        }
        .success-overlay h3 {
            font-family: var(--font-display);
            font-size: 1.3rem;
            font-weight: 900;
            letter-spacing: -0.04em;
        }
        .success-overlay p { color: var(--muted); font-size: 13px; }

        .redirect-bar {
            width: 140px; height: 3px;
            background: var(--border);
            border-radius: 999px;
            overflow: hidden;
        }
        .redirect-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent), var(--accent-2));
            border-radius: 999px;
            width: 0%;
            animation: fillBar 2s ease forwards;
        }
        @@keyframes fillBar { to { width: 100%; } }

        /* Animations */
        @@keyframes slideDown {
            from { opacity: 0; transform: translateY(-16px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 999px; }

        /* ── RESPONSIVE ── */
        @@media (max-width: 860px) {
            .page { grid-template-columns: 1fr; }

            .left-panel {
                padding: 28px 24px 32px;
                border-right: none;
                border-bottom: 1px solid var(--border);
            }
            .left-panel::after { display: none; }

            .hero h1 { font-size: 2.1rem; }
            .hero p { font-size: 14px; }
            .stats-strip { gap: 20px; }
            .testimonial { display: none; }

            .right-panel { padding: 32px 20px 40px; }
        }

        @@media (max-width: 480px) {
            .left-panel { padding: 24px 20px; }
            .hero h1 { font-size: 1.8rem; }
            .stats-strip { display: none; }

            .login-card { border-radius: 18px; }
            .card-header { padding: 22px 22px 0; }
            .demo-badge { margin: 14px 22px 0; width: calc(100% - 44px); }
            .card-body { padding: 14px 22px 0; }
            .card-footer { padding: 18px 22px 22px; }
            .terms { padding: 0 22px 20px; }
        }
    </style>
</head>
<body>

<div class="bg-layer">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="grid-overlay"></div>
</div>

<div class="page">

    <!-- ── LEFT PANEL ── -->
    <div class="left-panel">
        <div class="brand">
            <div class="logo-mark">BT</div>
            <div class="logo-text">Bug<span>Track</span></div>
        </div>

        <div class="hero">
            <div class="hero-eyebrow">Issue Tracking Platform</div>
            <h1>Bugs don't<br>stand a<br><span class="highlight">chance.</span></h1>
            <p>Track, triage, and resolve issues faster. BugTrack gives your team a single source of truth for every ticket, sprint, and release.</p>

            <div class="stats-strip">
                <div class="stat-item">
                    <div class="val">2.4k</div>
                    <div class="lbl">Tickets closed</div>
                </div>
                <div class="stat-item" style="border-left:1px solid var(--border);padding-left:28px;">
                    <div class="val">18</div>
                    <div class="lbl">Active projects</div>
                </div>
                <div class="stat-item" style="border-left:1px solid var(--border);padding-left:28px;">
                    <div class="val">99%</div>
                    <div class="lbl">Uptime SLA</div>
                </div>
            </div>
        </div>

        <div class="testimonial">
            <p>BugTrack cut our average resolution time in half. The team loves the clean interface — issues actually get closed now.</p>
            <div class="testimonial-author">
                <div class="t-avatar">MC</div>
                <div>
                    <div class="t-name">M. Chen</div>
                    <div class="t-role">Lead Engineer</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── RIGHT PANEL ── -->
    <div class="right-panel">
        <div class="login-card" style="position:relative;">

            <!-- Success overlay -->
            <div class="success-overlay" id="successOverlay">
                <div class="success-icon">
                    <svg width="28" height="28" fill="none" stroke="var(--accent)" stroke-width="2.5" viewBox="0 0 24 24">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                </div>
                <h3>Welcome back!</h3>
                <p>Redirecting to your dashboard…</p>
                <div class="redirect-bar"><div class="redirect-fill" id="redirectFill"></div></div>
            </div>

            <!-- Card header -->
            <div class="card-header">
                <h2>Sign in</h2>
                <p>Welcome back — let's pick up where you left off.</p>
            </div>

            <!-- Demo badge -->
            <button class="demo-badge" id="demoFillBtn" type="button">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="16"/>
                    <line x1="8" y1="12" x2="16" y2="12"/>
                </svg>
                Use demo credentials
            </button>

            <div class="divider">or sign in manually</div>

            <!-- Form -->
            <div class="card-body">
                <div class="form-group">
                    <label class="form-label" for="email">Email</label>
                    <div class="input-wrap">
                        <input class="form-control" id="email" type="email" placeholder="you@example.com" autocomplete="email" />
                        <svg class="input-icon" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22 6 12 13 2 6"/>
                        </svg>
                    </div>
                    <span class="error-msg" id="emailError">Please enter a valid email address.</span>
                </div>

                <div class="form-group">
                    <label class="form-label" for="password">Password</label>
                    <div class="input-wrap">
                        <input class="form-control" id="password" type="password" placeholder="••••••••••" autocomplete="current-password" />
                        <svg class="input-icon" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0110 0v4"/>
                        </svg>
                        <button class="pwd-toggle" id="togglePwd" type="button" tabindex="-1" title="Toggle password">
                            <svg id="eyeIcon" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                    <span class="error-msg" id="passwordError">Password is required.</span>
                </div>

                <div class="meta-row">
                    <label class="remember">
                        <input type="checkbox" id="rememberMe" checked />
                        <div class="check-box">
                            <svg width="9" height="9" fill="none" stroke="#030810" stroke-width="3" viewBox="0 0 24 24">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </div>
                        <span class="remember-label">Keep me signed in</span>
                    </label>
                    <a href="#" class="forgot-link">Forgot password?</a>
                </div>
            </div>

            <!-- Submit -->
            <div style="padding:18px 28px 0;">
                <button class="btn-submit" id="loginBtn" type="button">
                    <div class="spinner"></div>
                    <span class="btn-text">Sign In</span>
                    <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                    </svg>
                </button>
            </div>

            <!-- Footer -->
            <div class="card-footer">
                <p>Don't have an account? <a href="#" class="signup-link">Request access →</a></p>
            </div>

            <p class="terms">
                By signing in you agree to our <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>.
            </p>
        </div>
    </div>
</div>

<script>
    // Demo credentials
    const DEMO = { email: "demo@bugtrack.io", password: "bugtrack2024" };
    const REAL = { email: "rafael.parra@bugtrack.io", password: "Admin@2024!" };

    const emailEl    = document.getElementById("email");
    const passwordEl = document.getElementById("password");
    const loginBtn   = document.getElementById("loginBtn");
    const demoBtn    = document.getElementById("demoFillBtn");
    const togglePwd  = document.getElementById("togglePwd");
    const eyeIcon    = document.getElementById("eyeIcon");

    // ── Pre-fill with demo credentials on load ──
    function typeFill(el, text, delay = 0) {
        let i = 0;
        setTimeout(() => {
            const iv = setInterval(() => {
                el.value += text[i++];
                if (i >= text.length) clearInterval(iv);
            }, 28);
        }, delay);
    }

    // Auto-fill demo credentials with a typing animation on load
    window.addEventListener("DOMContentLoaded", () => {
        setTimeout(() => {
            typeFill(emailEl,    DEMO.email,    200);
            typeFill(passwordEl, DEMO.password, 800);
        }, 400);
    });

    // Demo button — re-fill instantly
    demoBtn.addEventListener("click", () => {
        emailEl.value    = DEMO.email;
        passwordEl.value = DEMO.password;
        emailEl.classList.remove("error");
        passwordEl.classList.remove("error");
        document.getElementById("emailError").classList.remove("show");
        document.getElementById("passwordError").classList.remove("show");
        emailEl.focus();

        // Pulse button
        demoBtn.style.transform = "scale(0.97)";
        setTimeout(() => demoBtn.style.transform = "", 150);
    });

    // ── Password toggle ──
    const eyeOpen = `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
    const eyeOff  = `<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>`;

    togglePwd.addEventListener("click", () => {
        const isText = passwordEl.type === "text";
        passwordEl.type = isText ? "password" : "text";
        eyeIcon.innerHTML = isText ? eyeOpen : eyeOff;
    });

    // ── Validation ──
    function validate() {
        let ok = true;
        const emailOk = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(emailEl.value.trim());
        const pwdOk   = passwordEl.value.length >= 4;

        emailEl.classList.toggle("error", !emailOk);
        document.getElementById("emailError").classList.toggle("show", !emailOk);
        passwordEl.classList.toggle("error", !pwdOk);
        document.getElementById("passwordError").classList.toggle("show", !pwdOk);

        return emailOk && pwdOk;
    }

    // Clear errors on input
    emailEl.addEventListener("input",    () => { emailEl.classList.remove("error"); document.getElementById("emailError").classList.remove("show"); });
    passwordEl.addEventListener("input", () => { passwordEl.classList.remove("error"); document.getElementById("passwordError").classList.remove("show"); });

    // Enter key submit
    [emailEl, passwordEl].forEach(el => {
        el.addEventListener("keydown", e => { if (e.key === "Enter") loginBtn.click(); });
    });

    // ── Login flow ──
        loginBtn.addEventListener("click", async () => {
            if (!validate()) return;

            const email = emailEl.value.trim();
            const pwd = passwordEl.value;

            loginBtn.classList.add("loading");
            loginBtn.disabled = true;

            try {
                const response = await fetch("@demoLoginUrl", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        email: email,
                        password: pwd
                    })
                });

                if (!response.ok) {
                    throw new Error("Invalid email or password. Try the demo credentials.");
                }

                const result = await response.json();

                const overlay = document.getElementById("successOverlay");
                overlay.classList.add("show");

                setTimeout(() => {
                    window.location.href = result.redirectUrl || "@ticketsUrl";
                }, 1400);
            } catch (err) {
                emailEl.classList.add("error");
                passwordEl.classList.add("error");

                const error = document.getElementById("passwordError");
                error.textContent = err.message || "Invalid email or password.";
                error.classList.add("show");

                passwordEl.value = "";
                passwordEl.focus();

                loginBtn.classList.remove("loading");
                loginBtn.disabled = false;
            }
        });
</script>
</body>
</html>